---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Commander — Les 3D d'Adrianne" description="Faites une demande d'impression 3D personnalisée à Adrianne.">
  <Nav />
  <main>
    <section class="contact-hero">
      <div class="container">
        <p class="eyebrow">Restons en contact</p>
        <h1>Faire une demande</h1>
        <p class="sub">Décrivez votre projet et je vous réponds rapidement avec un devis personnalisé.</p>
      </div>
    </section>

    <section class="contact-body">
      <div class="container form-layout">

        <!-- Infos -->
        <div class="contact-info reveal">
          <h2>Avant de commander</h2>
          <div class="info-cards">
            <div class="info-card">
              <span class="ic-icon">⏱️</span>
              <div>
                <p class="ic-title">Délai de livraison</p>
                <p class="ic-text">3 à 7 jours selon la complexité de la pièce</p>
              </div>
            </div>
            <div class="info-card">
              <span class="ic-icon">🎨</span>
              <div>
                <p class="ic-title">Couleurs disponibles</p>
                <p class="ic-text">Large choix de filaments PLA, ABS et ASA. Précisez vos préférences dans le formulaire.</p>
              </div>
            </div>
            <div class="info-card">
              <span class="ic-icon">📦</span>
              <div>
                <p class="ic-title">Livraison</p>
                <p class="ic-text">Remise en main propre ou envoi postal sécurisé</p>
              </div>
            </div>
            <div class="info-card">
              <span class="ic-icon">💬</span>
              <div>
                <p class="ic-title">Questions ?</p>
                <p class="ic-text">N'hésitez pas à décrire votre idée même si elle est encore floue !</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="form-wrap reveal">
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST">
            <!-- Web3Forms access key — remplace par ta clé -->
            <input type="hidden" name="access_key" value="1e67e4bf-479c-41eb-8587-f407dce6e775" />
            <input type="hidden" name="subject" value="Nouvelle commande — Les 3D d'Adrianne" />
            <input type="hidden" name="from_name" value="Site Les 3D d'Adrianne" />
            <input type="checkbox" name="botcheck" style="display:none" />

            <div class="form-row">
              <div class="field">
                <label for="name">Prénom & Nom <span class="req">*</span></label>
                <input type="text" id="name" name="name" placeholder="Marie Tremblay" required />
              </div>
              <div class="field">
                <label for="email">Adresse courriel <span class="req">*</span></label>
                <input type="email" id="email" name="email" placeholder="marie@exemple.com" required />
              </div>
            </div>

            <div class="form-row">
              <div class="field">
                <label for="phone">Téléphone <span class="opt">(optionnel)</span></label>
                <input type="tel" id="phone" name="phone" placeholder="418-555-0000" />
              </div>
              <div class="field">
                <label for="type">Type d'impression <span class="req">*</span></label>
                <select id="type" name="type" required>
                  <option value="" disabled selected>Choisir une catégorie…</option>
                  <option value="Figurine">Figurine / Personnage</option>
                  <option value="Décoration">Objet décoratif</option>
                  <option value="Utilitaire">Pièce utilitaire</option>
                  <option value="Cadeau">Cadeau personnalisé</option>
                  <option value="Autre">Autre</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label>Couleur(s) souhaitée(s) <span class="opt">(optionnel)</span></label>
              <input type="hidden" id="colors" name="colors" value="" />
              <div id="color-swatches" class="swatches-wrap">
                <span class="swatches-loading">Chargement des couleurs…</span>
              </div>
            </div>

            <div class="field">
              <label for="budget">Budget approximatif <span class="opt">(optionnel)</span></label>
              <select id="budget" name="budget">
                <option value="" disabled selected>Sélectionner…</option>
                <option value="Moins de 10$">Moins de 10 $</option>
                <option value="10–25$">10 $ – 25 $</option>
                <option value="25–50$">25 $ – 50 $</option>
                <option value="50$ et plus">50 $ et plus</option>
                <option value="À discuter">À discuter</option>
              </select>
            </div>

            <div class="field">
              <label for="description">Décrivez votre projet <span class="req">*</span></label>
              <textarea id="description" name="description" rows="5"
                placeholder="Décrivez votre idée en détail : dimensions souhaitées, référence d'image, utilisation prévue, urgence, etc." required></textarea>
            </div>

            <div class="field field-check">
              <label class="check-label">
                <input type="checkbox" name="consent" required />
                <span>J'accepte que mes informations soient utilisées pour traiter ma demande <span class="req">*</span></span>
              </label>
            </div>

            <button type="submit" class="submit-btn" id="submit-btn">
              <span id="btn-text">Envoyer la demande</span>
              <span id="btn-spinner" style="display:none">Envoi en cours…</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </form>

          <div id="success-msg" class="success-msg" style="display:none">
            <span class="success-icon">✅</span>
            <h3>Demande envoyée avec succès !</h3>
            <p>Merci pour votre message. Je vous répondrai dans les plus brefs délais avec un devis personnalisé.</p>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form    = document.getElementById('contact-form');
  const btn     = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const spinner = document.getElementById('btn-spinner');
  const success = document.getElementById('success-msg');

  // Pré-remplir si un produit est passé en URL
  const params      = new URLSearchParams(window.location.search);
  const produit     = params.get('produit');
  const inspiration = params.get('inspiration');

  if (produit) {
    const desc = document.getElementById('description');
    if (desc) desc.value = `Commande pour : ${produit}\n\n`;
    desc?.focus();
    const banner = document.createElement('div');
    banner.className = 'prefill-banner';
    banner.innerHTML = `✨ Commande pré-remplie pour <strong>${produit}</strong>`;
    form?.prepend(banner);
  } else if (inspiration) {
    const desc = document.getElementById('description');
    if (desc) desc.value = `Je suis intéressé·e par une création similaire à : ${inspiration}\n\n`;
    desc?.focus();
    const banner = document.createElement('div');
    banner.className = 'prefill-banner';
    banner.innerHTML = `✨ Inspiration : <strong>${inspiration}</strong> — décris ce que tu souhaites ci-dessous !`;
    form?.prepend(banner);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true; btnText.style.display = 'none'; spinner.style.display = 'inline';
    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
      const data = await res.json();
      if (data.success) {
        form.style.display = 'none'; success.style.display = 'flex';
      } else { throw new Error(); }
    } catch {
      btn.disabled = false; btnText.style.display = 'inline'; spinner.style.display = 'none';
      alert('Une erreur est survenue. Veuillez réessayer.');
    }
  });

  // ── Sélecteur de couleurs de filaments ───────────────────
  import { createClient } from '@supabase/supabase-js';
  const sb2 = createClient(
    'https://gnpjilwdehxsafdqdtak.supabase.co',
    'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImducGppbHdkZWh4c2FmZHFkdGFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Nzk3NjIsImV4cCI6MjA5NTU1NTc2Mn0.iFYR9r5ZZsKcc9n2N8jPtFTLs0QDTIqR3KMCMhCdSdA'
  );

  const colorsInput = document.getElementById('colors');
  const swatchContainer = document.getElementById('color-swatches');
  const selectedColors = new Set();

  function createSwatch(name, hex, type) {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'swatch-btn';
    btn.dataset.name = name;
    btn.innerHTML = `
      <span class="swatch-circle" style="background:${hex}">
        <span class="swatch-check">✓</span>
      </span>
      <span class="swatch-label">${name}</span>
      ${type ? `<span class="swatch-type">${type}</span>` : ''}
    `;
    btn.addEventListener('click', () => {
      if (name === 'Sans préférence') {
        const wasSelected = btn.classList.contains('selected');
        swatchContainer.querySelectorAll('.swatch-btn').forEach(b => b.classList.remove('selected'));
        selectedColors.clear();
        if (!wasSelected) { btn.classList.add('selected'); selectedColors.add('Sans préférence'); }
      } else {
        swatchContainer.querySelector('[data-name="Sans préférence"]')?.classList.remove('selected');
        selectedColors.delete('Sans préférence');
        btn.classList.toggle('selected');
        if (btn.classList.contains('selected')) selectedColors.add(name);
        else selectedColors.delete(name);
      }
      colorsInput.value = selectedColors.size > 0 ? [...selectedColors].join(', ') : '';
    });
    return btn;
  }

  async function initSwatches() {
    try {
      const { data: filaments } = await sb2.from('adrianne_filaments').select('*').eq('is_available', true).order('filament_type').order('name');
      swatchContainer.innerHTML = '';
      swatchContainer.appendChild(createSwatch('Sans préférence', '#e8e8e8', ''));
      filaments?.forEach(f => swatchContainer.appendChild(createSwatch(f.name, f.hex_color, f.filament_type)));
    } catch {
      swatchContainer.innerHTML = '';
      const fallback = document.createElement('input');
      fallback.type = 'text';
      fallback.placeholder = 'ex: blanc, noir, rouge — ou sans préférence';
      fallback.className = 'fallback-input';
      fallback.addEventListener('input', e => { colorsInput.value = e.target.value; });
      swatchContainer.appendChild(fallback);
    }
  }

  initSwatches();
</script>

<style>
  main { padding-top: 68px; }
  .eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }

  /* Hero */
  .contact-hero { padding: 5rem 2rem 3rem; text-align: center; border-bottom: 1px solid var(--border); }
  .contact-hero h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); margin-bottom: 1rem; }
  .contact-hero .sub { font-size: 0.95rem; color: var(--text-2); max-width: 420px; margin: 0 auto; line-height: 1.75; }

  /* Layout */
  .contact-body { padding: 5rem 2rem 6rem; }
  .form-layout { display: grid; grid-template-columns: 320px 1fr; gap: 5rem; align-items: start; }

  /* Info cards */
  .contact-info h2 { font-size: 1.5rem; margin-bottom: 1.5rem; }
  .info-cards { display: flex; flex-direction: column; gap: 1rem; }
  .info-card { display: flex; gap: 0.85rem; align-items: flex-start; padding: 1rem; background: var(--white); border: 1px solid var(--border); border-radius: 12px; }
  .ic-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 1px; }
  .ic-title { font-size: 0.85rem; font-weight: 600; margin-bottom: 0.2rem; }
  .ic-text  { font-size: 0.8rem; color: var(--text-2); line-height: 1.55; }

  /* Form */
  .form-wrap { background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 2.5rem; box-shadow: 0 4px 30px rgba(0,0,0,0.04); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.25rem; }
  .field label { font-size: 0.8rem; font-weight: 600; color: var(--text); letter-spacing: 0.02em; }
  .req { color: var(--accent); }
  .opt { font-weight: 400; color: var(--text-2); }
  .field input, .field select, .field textarea {
    background: var(--bg); border: 1.5px solid var(--border); color: var(--text);
    border-radius: 10px; padding: 0.7rem 1rem; font-size: 0.875rem;
    outline: none; font-family: 'DM Sans', sans-serif; transition: border-color 0.2s;
    width: 100%;
  }
  .field input:focus, .field select:focus, .field textarea:focus { border-color: var(--accent); }
  .field input::placeholder, .field textarea::placeholder { color: rgba(13,27,46,0.3); }
  .field textarea { resize: vertical; min-height: 120px; }
  .field-check { margin-top: 0.5rem; }
  .check-label { display: flex; align-items: flex-start; gap: 0.6rem; cursor: pointer; }
  .check-label input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }
  .check-label span { font-size: 0.8rem; color: var(--text-2); line-height: 1.5; }

  .submit-btn {
    width: 100%; padding: 0.9rem 2rem; margin-top: 0.5rem;
    background: var(--accent); color: var(--white); border: none;
    border-radius: 999px; font-size: 0.9rem; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.6rem;
    font-family: 'Jost', sans-serif; letter-spacing: 0.03em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .submit-btn:hover:not(:disabled) { background: var(--accent-d); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(42,92,180,0.3); }
  .submit-btn:disabled { opacity: 0.7; cursor: not-allowed; }

  .success-msg { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 3rem 2rem; gap: 0.75rem; }
  .success-icon { font-size: 2.5rem; }
  .success-msg h3 { font-size: 1.3rem; font-family: 'Cormorant Garamond', serif; }
  .success-msg p  { font-size: 0.875rem; color: var(--text-2); max-width: 320px; line-height: 1.65; }

  .prefill-banner {
    background: rgba(42,92,180,0.07); border: 1px solid rgba(42,92,180,0.2);
    border-radius: 10px; padding: 0.75rem 1rem; margin-bottom: 1.5rem;
    font-size: 0.84rem; color: var(--accent);
  }
  /* Swatch couleurs — :global() requis car les boutons sont créés dynamiquement en JS */
  .swatches-wrap { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.35rem; min-height: 70px; align-items: flex-start; align-content: flex-start; }
  .swatches-loading { font-size: 0.8rem; color: var(--text-2); font-style: italic; align-self: center; }
  :global(.swatch-btn) { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; background: none; border: 2px solid var(--border); border-radius: 12px; padding: 0.55rem 0.5rem; cursor: pointer; transition: border-color 0.2s, transform 0.15s, background 0.2s; min-width: 60px; font-family: 'DM Sans', sans-serif; }
  :global(.swatch-btn:hover) { border-color: var(--accent); transform: translateY(-1px); }
  :global(.swatch-btn.selected) { border-color: var(--accent); background: rgba(42,92,180,0.07); }
  :global(.swatch-circle) { width: 30px; height: 30px; border-radius: 50%; border: 2px solid rgba(0,0,0,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  :global(.swatch-check) { display: none; font-size: 0.75rem; font-weight: 700; color: white; text-shadow: 0 1px 3px rgba(0,0,0,0.5); }
  :global(.swatch-btn.selected .swatch-check) { display: block; }
  :global(.swatch-label) { font-size: 0.67rem; color: var(--text); text-align: center; line-height: 1.2; font-weight: 500; max-width: 56px; word-wrap: break-word; }
  :global(.swatch-type) { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.05em; color: var(--accent); text-transform: uppercase; }
  :global(.fallback-input) { width: 100%; padding: 0.7rem 1rem; border: 1.5px solid var(--border); border-radius: 10px; font-size: 0.875rem; outline: none; font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); transition: border-color 0.2s; }
  :global(.fallback-input:focus) { border-color: var(--accent); }

  @media (max-width: 900px) { .form-layout { grid-template-columns: 1fr; gap: 2.5rem; } }
  @media (max-width: 560px) { .form-row { grid-template-columns: 1fr; } .form-wrap { padding: 1.5rem; } }
</style>
