  .inv-doc-logo { display: flex; align-items: center; gap: 0.75rem; }
  .idl-circle { width: 40px; height: 40px; border-radius: 50%; background: var(--accent); color: #fff; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.3rem; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .inv-logo-n { display: block; font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: var(--dark); line-height: 1.2; }
  .inv-logo-s { display: block; font-size: 0.58rem; color: var(--text-2); letter-spacing: 0.08em; }
  .inv-doc-meta { text-align: right; display: flex; flex-direction: column; gap: 0.4rem; align-items: flex-end; }
  .inv-doc-title  { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 600; letter-spacing: 0.08em; color: var(--accent); }
