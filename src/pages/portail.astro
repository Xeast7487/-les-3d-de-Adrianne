  /* STATS */
  .dash-stats { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .ds-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 1.1rem 1.4rem; display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 160px; }
