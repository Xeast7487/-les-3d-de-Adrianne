  .ilr-arrow  { color: var(--text-2); font-size: 1rem; text-align: center; }
  .empty-inv { text-align: center; padding: 4rem 2rem; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; color: var(--text-2); background: #fff; border: 1px solid var(--border); border-radius: 14px; }
