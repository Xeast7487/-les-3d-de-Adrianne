  .inv-list-row { display: grid; grid-template-columns: 160px 1fr 150px 130px 130px 40px; gap: 1rem; padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); align-items: center; cursor: pointer; transition: background 0.15s; }
  .inv-list-row:last-child { border-bottom: none; }
  .inv-list-row:hover { background: rgba(42,92,180,0.03); }
  .ilr-num    { font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: 0.95rem; color: var(--dark); }
  .ilr-title  { font-size: 0.875rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
