  /* STATUS PILLS */
  .status-pill { display: inline-block; font-size: 0.68rem; font-weight: 700; padding: 0.25rem 0.7rem; border-radius: 999px; letter-spacing: 0.04em; white-space: nowrap; }
  .sp-pending   { background: rgba(245,158,11,0.1);  color: #d97706; }
