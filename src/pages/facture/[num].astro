---
import { createClient } from '@supabase/supabase-js';

const { num } = Astro.params;

const SB_URL = 'https://gnpjilwdehxsafdqdtak.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImducGppbHdkZWh4c2FmZHFkdGFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Nzk3NjIsImV4cCI6MjA5NTU1NTc2Mn0.iFYR9r5ZZsKcc9n2N8jPtFTLs0QDTIqR3KMCMhCdSdA';
const sb = createClient(SB_URL, SB_KEY);

const { data: order } = await sb
  .from('adrianne_orders')
  .select('*')
  .eq('order_number', (num ?? '').toUpperCase())
  .maybeSingle();

const notFound = !order;

const issueDate = order
  ? new Date(order.created_at).toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const total = order?.total_cents != null
  ? (order.total_cents / 100).toLocaleString('fr-CA', { style: 'currency', currency: 'CAD' })
  : null;

const tps = order?.total_cents != null ? (order.total_cents * 0.05 / 100).toLocaleString('fr-CA', { style: 'currency', currency: 'CAD' }) : null;
const tvq = order?.total_cents != null ? (order.total_cents * 0.09975 / 100).toLocaleString('fr-CA', { style: 'currency', currency: 'CAD' }) : null;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Facture {num?.toUpperCase()} — Les 3D d'Adrianne</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent: #2A5CB4;
      --text: #0d1b2e;
      --text-2: #6b7a90;
      --border: #e2e8f0;
      --bg: #f8f9fb;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--bg);
      padding: 2rem 1rem;
      min-height: 100vh;
    }

    .page {
      background: white;
      max-width: 720px;
      margin: 0 auto;
      border-radius: 16px;
      box-shadow: 0 4px 32px rgba(0,0,0,0.08);
      overflow: hidden;
    }

    /* ── Header ── */
    .inv-header {
      background: var(--accent);
      color: white;
      padding: 2.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
    }

    .brand { display: flex; flex-direction: column; gap: 0.3rem; }
    .brand-logo {
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(255,255,255,0.2);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.6rem; font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .brand-name { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; }
    .brand-sub { font-size: 0.78rem; opacity: 0.75; }

    .inv-meta { text-align: right; }
    .inv-title { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; letter-spacing: 0.02em; opacity: 0.95; }
    .inv-num { font-size: 0.8rem; opacity: 0.8; margin-top: 0.25rem; font-weight: 500; letter-spacing: 0.05em; }
    .inv-date { font-size: 0.78rem; opacity: 0.7; margin-top: 0.15rem; }

    /* ── Body ── */
    .inv-body { padding: 2.5rem 3rem; }

    /* Bill to */
    .section-label {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-2);
      margin-bottom: 0.5rem;
    }
    .bill-to { margin-bottom: 2.5rem; }
    .bill-name { font-size: 1.1rem; font-weight: 600; }
    .bill-email { font-size: 0.85rem; color: var(--text-2); margin-top: 0.15rem; }

    /* Items table */
    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
    .items-table th {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--text-2);
      padding: 0.5rem 0; border-bottom: 2px solid var(--border);
      text-align: left;
    }
    .items-table th:last-child, .items-table td:last-child { text-align: right; }
    .items-table td {
      padding: 1rem 0; border-bottom: 1px solid var(--border);
      font-size: 0.88rem; vertical-align: top;
    }
    .item-name { font-weight: 600; margin-bottom: 0.15rem; }
    .item-desc { font-size: 0.78rem; color: var(--text-2); line-height: 1.5; }
    .item-qty { color: var(--text-2); }
    .item-price { font-weight: 600; }

    /* Totals */
    .totals { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; margin-bottom: 2.5rem; }
    .total-row { display: flex; gap: 3rem; justify-content: flex-end; font-size: 0.85rem; color: var(--text-2); }
    .total-row span:last-child { min-width: 100px; text-align: right; }
    .total-divider { width: 240px; height: 1px; background: var(--border); margin: 0.4rem 0; }
    .total-final { display: flex; gap: 3rem; justify-content: flex-end; font-size: 1rem; font-weight: 700; color: var(--text); }
    .total-final span:last-child { min-width: 100px; text-align: right; color: var(--accent); }

    .no-tax-note { font-size: 0.75rem; color: var(--text-2); margin-top: 0.5rem; text-align: right; font-style: italic; }

    /* Notes */
    .notes-section {
      background: var(--bg); border-radius: 10px; padding: 1rem 1.25rem;
      margin-bottom: 2rem; font-size: 0.85rem; color: var(--text-2);
      line-height: 1.6; border: 1px solid var(--border);
    }
    .notes-section p { color: var(--text); margin-top: 0.25rem; }

    /* Footer */
    .inv-footer {
      border-top: 1px solid var(--border);
      padding: 1.5rem 3rem;
      display: flex; justify-content: space-between; align-items: center;
      gap: 1rem;
      font-size: 0.78rem; color: var(--text-2);
    }
    .inv-footer .thank-you { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-style: italic; color: var(--accent); }

    /* Print button */
    .print-bar {
      max-width: 720px; margin: 0 auto 1.5rem;
      display: flex; gap: 0.75rem; justify-content: flex-end;
    }
    .print-btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--accent); color: white;
      border: none; border-radius: 999px;
      padding: 0.6rem 1.3rem; font-size: 0.83rem; font-weight: 600;
      cursor: pointer; font-family: 'DM Sans', sans-serif;
      transition: background 0.2s;
    }
    .print-btn:hover { background: #1e4a99; }
    .back-link {
      display: inline-flex; align-items: center; gap: 0.5rem;
      color: var(--text-2); font-size: 0.83rem; text-decoration: none;
      border: 1.5px solid var(--border); border-radius: 999px;
      padding: 0.6rem 1.3rem; transition: border-color 0.2s, color 0.2s;
    }
    .back-link:hover { border-color: var(--accent); color: var(--accent); }

    /* Not found */
    .not-found {
      text-align: center; padding: 4rem 2rem;
      font-size: 0.95rem; color: var(--text-2);
    }
    .not-found h2 { font-size: 1.5rem; color: var(--text); margin-bottom: 0.5rem; }

    @media print {
      body { background: white; padding: 0; }
      .page { box-shadow: none; border-radius: 0; }
      .print-bar { display: none; }
    }

    @media (max-width: 600px) {
      .inv-header { flex-direction: column; padding: 2rem; }
      .inv-meta { text-align: left; }
      .inv-body { padding: 2rem; }
      .inv-footer { flex-direction: column; align-items: flex-start; padding: 1.5rem 2rem; }
    }
  </style>
</head>
<body>

{notFound ? (
  <div class="page not-found">
    <h2>Facture introuvable</h2>
    <p>Aucune commande ne correspond au numéro <strong>{num?.toUpperCase()}</strong>.</p>
    <br />
    <a href="/admin" style="color:var(--accent)">← Retour à l'admin</a>
  </div>
) : (
  <>
    <div class="print-bar">
      <a href="/admin" class="back-link">← Admin</a>
      <button class="print-btn" onclick="window.print()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Imprimer / Enregistrer PDF
      </button>
    </div>

    <div class="page">
      <!-- Header -->
      <div class="inv-header">
        <div class="brand">
          <div class="brand-logo">A</div>
          <div class="brand-name">Les 3D d'Adrianne</div>
          <div class="brand-sub">Impressions 3D personnalisées</div>
        </div>
        <div class="inv-meta">
          <div class="inv-title">Facture</div>
          <div class="inv-num">{order.order_number}</div>
          <div class="inv-date">Émise le {issueDate}</div>
        </div>
      </div>

      <!-- Body -->
      <div class="inv-body">

        <!-- Bill to -->
        <div class="bill-to">
          <div class="section-label">Facturé à</div>
          <div class="bill-name">{order.client_name}</div>
          {order.client_email && <div class="bill-email">{order.client_email}</div>}
        </div>

        <!-- Items -->
        <table class="items-table">
          <thead>
            <tr>
              <th>Description</th>
              <th style="width:60px;text-align:center">Qté</th>
              <th style="width:120px">Montant</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <div class="item-name">Commande spéciale — Impression 3D</div>
                <div class="item-desc">{order.description}</div>
              </td>
              <td style="text-align:center" class="item-qty">1</td>
              <td class="item-price">{total ?? '—'}</td>
            </tr>
          </tbody>
        </table>

        <!-- Totals -->
        {total != null ? (
          <div class="totals">
            <div class="total-row">
              <span>Sous-total</span>
              <span>{total}</span>
            </div>
            <div class="total-row">
              <span>TPS (5 %)</span>
              <span>{tps}</span>
            </div>
            <div class="total-row">
              <span>TVQ (9,975 %)</span>
              <span>{tvq}</span>
            </div>
            <div class="total-divider"></div>
            <div class="total-final">
              <span>Total</span>
              <span>{total}</span>
            </div>
            <div class="no-tax-note">* Montant total incluant les taxes, tel que convenu.</div>
          </div>
        ) : (
          <div class="totals">
            <div class="total-final">
              <span>Total</span>
              <span style="color:var(--text-2);font-style:italic;font-weight:400">À déterminer</span>
            </div>
          </div>
        )}

        <!-- Notes -->
        {order.notes && (
          <div class="notes-section">
            <div class="section-label">Note</div>
            <p>{order.notes}</p>
          </div>
        )}

      </div>

      <!-- Footer -->
      <div class="inv-footer">
        <div class="thank-you">Merci pour votre confiance !</div>
        <div style="text-align:right">
          <div>les3darianne.xyz</div>
          <div style="margin-top:0.15rem">Impressions 3D personnalisées</div>
        </div>
      </div>
    </div>
  </>
)}

</body>
</html>
