import { createClient } from '@supabase/supabase-js';
/* ══════════════════════════════════════════════════════════
   IMPORTANT — SQL à exécuter dans Supabase une seule fois :

   CREATE TABLE IF NOT EXISTS public.adrianne_prints (
     id          UUID        DEFAULT gen_random_uuid() PRIMARY KEY,
     name        TEXT        NOT NULL,
     description TEXT        DEFAULT '',
     category    TEXT        NOT NULL DEFAULT 'Divers',
     photo_url   TEXT        DEFAULT '',
     price_range TEXT        DEFAULT '',
     featured    BOOLEAN     DEFAULT false,
     created_at  TIMESTAMPTZ DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_prints ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_prints FOR ALL USING (true) WITH CHECK (true);

   -- Bucket Storage (dans Storage > New bucket) :
   Nom : adrianne-prints  |  Public : oui
   Puis dans Storage Policies :
   CREATE POLICY "public_read"   ON storage.objects FOR SELECT USING (bucket_id = 'adrianne-prints');
   CREATE POLICY "anon_upload"   ON storage.objects FOR INSERT WITH CHECK (bucket_id = 'adrianne-prints');
   CREATE POLICY "anon_delete"   ON storage.objects FOR DELETE USING (bucket_id = 'adrianne-prints');

   -- Multi-photos (à exécuter une seule fois) :
   ALTER TABLE public.adrianne_prints ADD COLUMN IF NOT EXISTS photo_urls TEXT[] DEFAULT '{}';

   -- Prix Stripe (à exécuter une seule fois) :
   ALTER TABLE public.adrianne_prints ADD COLUMN IF NOT EXISTS price_cents INTEGER DEFAULT NULL;
   UPDATE public.adrianne_prints SET photo_urls = ARRAY[photo_url] WHERE photo_url != '' AND (photo_urls IS NULL OR photo_urls = '{}');

   -- Réalisations (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.adrianne_realisations (
     id          UUID        DEFAULT gen_random_uuid() PRIMARY KEY,
     name        TEXT        NOT NULL,
     description TEXT        DEFAULT '',
     category    TEXT        NOT NULL DEFAULT 'Divers',
     photo_url   TEXT        DEFAULT '',
     photo_urls  TEXT[]      DEFAULT '{}',
     featured    BOOLEAN     DEFAULT false,
     created_at  TIMESTAMPTZ DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_realisations ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_realisations FOR ALL USING (true) WITH CHECK (true);

   -- Visites journalières (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.daily_visits (
     date  DATE    PRIMARY KEY DEFAULT CURRENT_DATE,
     count INTEGER NOT NULL    DEFAULT 0
   );
   ALTER TABLE public.daily_visits ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.daily_visits FOR ALL USING (true) WITH CHECK (true);

   CREATE OR REPLACE FUNCTION increment_daily_visit(visit_date DATE DEFAULT CURRENT_DATE)
   RETURNS VOID AS $$
   BEGIN
     INSERT INTO public.daily_visits (date, count) VALUES (visit_date, 1)
     ON CONFLICT (date) DO UPDATE SET count = daily_visits.count + 1;
   END;
   $$ LANGUAGE plpgsql SECURITY DEFINER;
   -- Commandes spéciales — colonnes facture (à exécuter une seule fois) :
   ALTER TABLE public.adrianne_orders ADD COLUMN IF NOT EXISTS client_email TEXT DEFAULT '';
   ALTER TABLE public.adrianne_orders ADD COLUMN IF NOT EXISTS total_cents INTEGER DEFAULT NULL;

   -- Couleurs de filament sur les commandes (à exécuter une seule fois) :
   ALTER TABLE public.adrianne_orders ADD COLUMN IF NOT EXISTS colors TEXT DEFAULT '';

   -- Filaments disponibles (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.adrianne_filaments (
     id            UUID        DEFAULT gen_random_uuid() PRIMARY KEY,
     name          TEXT        NOT NULL,
     hex_color     TEXT        NOT NULL DEFAULT '#888888',
     filament_type TEXT        NOT NULL DEFAULT 'PLA',
     is_available  BOOLEAN     DEFAULT TRUE,
     created_at    TIMESTAMPTZ DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_filaments ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_filaments FOR ALL USING (true) WITH CHECK (true);

   -- Clients portail (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.adrianne_clients (
     id            UUID        DEFAULT gen_random_uuid() PRIMARY KEY,
     name          TEXT        NOT NULL,
     email         TEXT        NOT NULL UNIQUE,
     company       TEXT        DEFAULT '',
     phone         TEXT        DEFAULT '',
     password_hash TEXT        DEFAULT '',
     created_at    TIMESTAMPTZ DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_clients ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_clients FOR ALL USING (true) WITH CHECK (true);

   -- Factures clients (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.adrianne_invoices (
     id             UUID          DEFAULT gen_random_uuid() PRIMARY KEY,
     client_id      UUID          REFERENCES public.adrianne_clients(id) ON DELETE CASCADE,
     invoice_number TEXT          NOT NULL,
     title          TEXT          NOT NULL DEFAULT '',
     items          JSONB         DEFAULT '[]',
     subtotal       NUMERIC(10,2) DEFAULT 0,
     tax_rate       NUMERIC(5,2)  DEFAULT 5,
     tax            NUMERIC(10,2) DEFAULT 0,
     tps_amount     NUMERIC(10,2) DEFAULT 0,
     tvq_amount     NUMERIC(10,2) DEFAULT 0,
     apply_tps      BOOLEAN       DEFAULT true,
     apply_tvq      BOOLEAN       DEFAULT true,
     total          NUMERIC(10,2) DEFAULT 0,
     status         TEXT          DEFAULT 'pending',
     due_date       DATE          DEFAULT NULL,
     notes          TEXT          DEFAULT '',
     created_at     TIMESTAMPTZ   DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_invoices ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_invoices FOR ALL USING (true) WITH CHECK (true);
══════════════════════════════════════════════════════════ */

