// ── Auth ─────────────────────────────────────────────────
const lock  = document.getElementById('lock');
const admin = document.getElementById('admin');
const pwdInput = document.getElementById('pwd');
const pwdErr   = document.getElementById('pwd-err');

function unlock() {
  if (pwdInput.value === ADMIN_PWD) {
    sessionStorage.setItem('adr-auth', '1');
    lock.style.display = 'none'; admin.style.display = 'block';
    loadPrints();
  } else { pwdErr.textContent = 'Mot de passe incorrect.'; pwdInput.value = ''; }
}
