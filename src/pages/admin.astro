---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Admin — Les 3D d'Adrianne">
  <Nav />
  <main>

    <!-- ─── Écran de connexion ──────────────────────────── -->
    <div id="lock">
      <div class="lock-card">
        <div class="lock-logo"><span class="logo-a">A</span></div>
        <h2>Espace admin</h2>
        <p>Entre ton mot de passe pour continuer</p>
        <input type="password" id="pwd" placeholder="Mot de passe" autofocus />
        <button id="pwd-btn" class="btn-primary">Accéder</button>
        <p id="pwd-err" class="err-msg"></p>
      </div>
    </div>

    <!-- ─── Interface admin ─────────────────────────────── -->
    <div id="admin" style="display:none">
      <div class="admin-wrap">

        <!-- Tabs -->
        <div class="admin-tabs">
          <button class="tab-btn active" data-tab="galerie">🖼️ Galerie</button>
          <button class="tab-btn" data-tab="realisations">🎨 Réalisations</button>
          <button class="tab-btn" data-tab="commandes">📦 Commandes</button>
          <button id="logout" class="btn-outline" style="margin-left:auto">Déconnexion</button>
        </div>

        <!-- ═══ TAB GALERIE ═══ -->
        <div id="tab-galerie" class="tab-content">
        <div class="admin-top">
          <div>
            <h1>Mes créations</h1>
            <p class="admin-sub">Gère ta galerie directement ici</p>
          </div>
          <button id="open-add" class="btn-primary">+ Ajouter une création</button>
        </div>

        <!-- Stats rapides -->
        <div id="admin-stats" class="stats-row"></div>

        <!-- Modal ajout / édition -->
        <div id="modal-overlay" class="modal-overlay" style="display:none">
          <div class="modal">
            <div class="modal-head">
              <h3 id="modal-title">Nouvelle création</h3>
              <button id="modal-close" class="modal-x">×</button>
            </div>
            <form id="print-form">
              <input type="hidden" id="edit-id" />

              <div class="mform-row">
                <div class="mfield">
                  <label>Nom <span class="req">*</span></label>
                  <input type="text" id="f-name" placeholder="ex: Figurine Dragon" required />
                </div>
                <div class="mfield">
                  <label>Catégorie <span class="req">*</span></label>
                  <select id="f-cat" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option>Figurines</option>
                    <option>Déco</option>
                    <option>Utilitaires</option>
                    <option>Cadeaux</option>
                    <option>Divers</option>
                  </select>
                </div>
              </div>

              <div class="mfield">
                <label>Description <span class="opt">(optionnel)</span></label>
                <textarea id="f-desc" rows="3" placeholder="Décris brièvement la pièce…"></textarea>
              </div>

              <div class="mform-row">
                <div class="mfield">
                  <label>Prix affiché <span class="opt">(optionnel)</span></label>
                  <input type="text" id="f-price" placeholder="ex: 15 $ – 25 $" />
                </div>
                <div class="mfield">
                  <label>Prix de vente $ <span class="opt">(Stripe — laisser vide si pas à vendre)</span></label>
                  <input type="number" id="f-price-sell" placeholder="ex: 25.00" step="0.01" min="0.50" />
                </div>
              </div>

              <div class="mfield mfield-check" style="margin-top:-0.5rem">
                <label class="check-lbl">
                  <input type="checkbox" id="f-featured" />
                  <span>⭐ Mettre en avant (coup de cœur)</span>
                </label>
              </div>

              <!-- Upload photos -->
              <div class="mfield">
                <label>Photos <span class="opt">(plusieurs possibles)</span></label>
                <div id="drop-zone" class="drop-zone">
                  <div id="drop-inner">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>Glisse des photos ici ou <label for="file-input" class="file-link">clique pour choisir</label></p>
                    <p class="drop-hint">JPG, PNG, WEBP · Max 5 Mo par photo · Plusieurs photos possibles</p>
                  </div>
                  <div id="photos-preview" class="photos-preview" style="display:none"></div>
                </div>
                <input type="file" id="file-input" accept="image/*" multiple style="display:none" />
                <div id="upload-progress" style="display:none" class="progress-wrap">
                  <div id="progress-bar" class="progress-bar"></div>
                  <span id="progress-label">0%</span>
                </div>
              </div>

              <div class="modal-foot">
                <button type="button" id="cancel-btn" class="btn-outline">Annuler</button>
                <button type="submit" id="save-btn" class="btn-primary">
                  <span id="save-text">Enregistrer</span>
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Liste des créations -->
        <div id="prints-list" class="prints-list"></div>
        <div id="list-empty" style="display:none" class="list-empty">
          <p>Aucune création pour l'instant. Clique sur « Ajouter une création » pour commencer !</p>
        </div>
        </div><!-- fin tab-galerie -->

        <!-- ═══ TAB RÉALISATIONS ═══ -->
        <div id="tab-realisations" class="tab-content" style="display:none">
        <div class="admin-top">
          <div>
            <h1>Réalisations</h1>
            <p class="admin-sub">Photos de tes créations passées — non disponibles à la vente</p>
          </div>
          <button id="open-real" class="btn-primary">+ Ajouter une réalisation</button>
        </div>

        <!-- Modal réalisation -->
        <div id="real-modal-overlay" class="modal-overlay" style="display:none">
          <div class="modal">
            <div class="modal-head">
              <h3 id="real-modal-title">Nouvelle réalisation</h3>
              <button id="real-modal-close" class="modal-x">×</button>
            </div>
            <form id="real-form">
              <input type="hidden" id="r-edit-id" />

              <div class="mform-row">
                <div class="mfield">
                  <label>Nom <span class="req">*</span></label>
                  <input type="text" id="r-name" placeholder="ex: Figurine Dragon Blanc" required />
                </div>
                <div class="mfield">
                  <label>Catégorie <span class="req">*</span></label>
                  <select id="r-cat" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option>Figurines</option>
                    <option>Déco</option>
                    <option>Utilitaires</option>
                    <option>Cadeaux</option>
                    <option>Divers</option>
                  </select>
                </div>
              </div>

              <div class="mfield">
                <label>Description <span class="opt">(optionnel)</span></label>
                <textarea id="r-desc" rows="3" placeholder="Décris la pièce, le contexte, le matériau utilisé…"></textarea>
              </div>

              <div class="mfield mfield-check">
                <label class="check-lbl">
                  <input type="checkbox" id="r-featured" />
                  <span>⭐ Mettre en avant (coup de cœur)</span>
                </label>
              </div>

              <!-- Upload photos -->
              <div class="mfield">
                <label>Photos <span class="opt">(plusieurs possibles)</span></label>
                <div id="real-drop-zone" class="drop-zone">
                  <div id="real-drop-inner">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>Glisse des photos ici ou <label for="real-file-input" class="file-link">clique pour choisir</label></p>
                    <p class="drop-hint">JPG, PNG, WEBP · Max 5 Mo par photo · Plusieurs photos possibles</p>
                  </div>
                  <div id="real-photos-preview" class="photos-preview" style="display:none"></div>
                </div>
                <input type="file" id="real-file-input" accept="image/*" multiple style="display:none" />
                <div id="real-upload-progress" style="display:none" class="progress-wrap">
                  <div id="real-progress-bar" class="progress-bar"></div>
                  <span id="real-progress-label">0%</span>
                </div>
              </div>

              <div class="modal-foot">
                <button type="button" id="real-cancel-btn" class="btn-outline">Annuler</button>
                <button type="submit" id="real-save-btn" class="btn-primary">
                  <span id="real-save-text">Enregistrer</span>
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Liste des réalisations -->
        <div id="real-list" class="prints-list"></div>
        <div id="real-empty" style="display:none" class="list-empty">
          <p>Aucune réalisation pour l'instant. Clique sur « Ajouter une réalisation » pour commencer !</p>
        </div>
        </div><!-- fin tab-realisations -->

        <!-- ═══ TAB COMMANDES ═══ -->
        <div id="tab-commandes" class="tab-content" style="display:none">
          <div class="admin-top">
            <div>
              <h1>Commandes</h1>
              <p class="admin-sub">Crée et gère le suivi des commandes de tes clients</p>
            </div>
            <button id="open-order" class="btn-primary">+ Nouvelle commande</button>
          </div>

          <!-- Modal commande -->
          <div id="order-modal-overlay" class="modal-overlay" style="display:none">
            <div class="modal">
              <div class="modal-head">
                <h3 id="order-modal-title">Nouvelle commande</h3>
                <button id="order-modal-close" class="modal-x">×</button>
              </div>
              <form id="order-form">
                <input type="hidden" id="o-edit-id" />
                <div class="mform-row">
                  <div class="mfield">
                    <label>Numéro de commande <span class="req">*</span></label>
                    <input type="text" id="o-num" placeholder="ex: ADR-001" required />
                  </div>
                  <div class="mfield">
                    <label>Nom du client <span class="req">*</span></label>
                    <input type="text" id="o-name" placeholder="Marie Tremblay" required />
                  </div>
                </div>
                <div class="mfield">
                  <label>Description de la commande <span class="req">*</span></label>
                  <textarea id="o-desc" rows="2" placeholder="ex: Figurine Dragon blanc 15cm" required></textarea>
                </div>
                <div class="mform-row">
                  <div class="mfield">
                    <label>Statut <span class="req">*</span></label>
                    <select id="o-status" required>
                      <option value="en_attente">📋 En attente</option>
                      <option value="confirme">✅ Confirmée</option>
                      <option value="impression">🖨️ En impression</option>
                      <option value="finition">✨ Finition</option>
                      <option value="pret">📦 Prête à livrer</option>
                      <option value="livre">🎉 Livrée</option>
                    </select>
                  </div>
                  <div class="mfield">
                    <label>Délai estimé (jours) <span class="req">*</span></label>
                    <input type="number" id="o-days" value="7" min="1" max="60" required />
                  </div>
                </div>
                <div class="mfield">
                  <label>Message pour le client <span class="opt">(optionnel)</span></label>
                  <textarea id="o-notes" rows="2" placeholder="ex: Votre commande est en cours, livraison prévue vendredi !"></textarea>
                </div>
                <div class="modal-foot">
                  <button type="button" id="order-cancel" class="btn-outline">Annuler</button>
                  <button type="submit" id="order-save" class="btn-primary">Enregistrer</button>
                </div>
              </form>
            </div>
          </div>

          <!-- Liste commandes -->
          <div id="orders-list" class="prints-list"></div>
          <div id="orders-empty" style="display:none" class="list-empty">
            <p>Aucune commande pour l'instant. Crée la première !</p>
          </div>
        </div><!-- fin tab-commandes -->

      </div>
    </div>

  </main>
</Layout>

<script>
import { createClient } from '@supabase/supabase-js';
/* ══════════════════════════════════════════════════════════
   IMPORTANT — SQL à exécuter dans Supabase une seule fois :

   CREATE TABLE IF NOT EXISTS public.adrianne_prints (
     id          UUID        DEFAULT gen_random_uuid() PRIMARY KEY,
     name        TEXT        NOT NULL,
     description TEXT        DEFAULT '',
     category    TEXT        NOT NULL DEFAULT 'Divers',
     photo_url   TEXT        DEFAULT '',
     price_range TEXT        DEFAULT '',
     featured    BOOLEAN     DEFAULT false,
     created_at  TIMESTAMPTZ DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_prints ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_prints FOR ALL USING (true) WITH CHECK (true);

   -- Bucket Storage (dans Storage > New bucket) :
   Nom : adrianne-prints  |  Public : oui
   Puis dans Storage Policies :
   CREATE POLICY "public_read"   ON storage.objects FOR SELECT USING (bucket_id = 'adrianne-prints');
   CREATE POLICY "anon_upload"   ON storage.objects FOR INSERT WITH CHECK (bucket_id = 'adrianne-prints');
   CREATE POLICY "anon_delete"   ON storage.objects FOR DELETE USING (bucket_id = 'adrianne-prints');

   -- Multi-photos (à exécuter une seule fois) :
   ALTER TABLE public.adrianne_prints ADD COLUMN IF NOT EXISTS photo_urls TEXT[] DEFAULT '{}';

   -- Prix Stripe (à exécuter une seule fois) :
   ALTER TABLE public.adrianne_prints ADD COLUMN IF NOT EXISTS price_cents INTEGER DEFAULT NULL;
   UPDATE public.adrianne_prints SET photo_urls = ARRAY[photo_url] WHERE photo_url != '' AND (photo_urls IS NULL OR photo_urls = '{}');

   -- Réalisations (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.adrianne_realisations (
     id          UUID        DEFAULT gen_random_uuid() PRIMARY KEY,
     name        TEXT        NOT NULL,
     description TEXT        DEFAULT '',
     category    TEXT        NOT NULL DEFAULT 'Divers',
     photo_url   TEXT        DEFAULT '',
     photo_urls  TEXT[]      DEFAULT '{}',
     featured    BOOLEAN     DEFAULT false,
     created_at  TIMESTAMPTZ DEFAULT NOW()
   );
   ALTER TABLE public.adrianne_realisations ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.adrianne_realisations FOR ALL USING (true) WITH CHECK (true);

   -- Visites journalières (à exécuter une seule fois) :
   CREATE TABLE IF NOT EXISTS public.daily_visits (
     date  DATE    PRIMARY KEY DEFAULT CURRENT_DATE,
     count INTEGER NOT NULL    DEFAULT 0
   );
   ALTER TABLE public.daily_visits ENABLE ROW LEVEL SECURITY;
   CREATE POLICY "open" ON public.daily_visits FOR ALL USING (true) WITH CHECK (true);

   CREATE OR REPLACE FUNCTION increment_daily_visit(visit_date DATE DEFAULT CURRENT_DATE)
   RETURNS VOID AS $$
   BEGIN
     INSERT INTO public.daily_visits (date, count) VALUES (visit_date, 1)
     ON CONFLICT (date) DO UPDATE SET count = daily_visits.count + 1;
   END;
   $$ LANGUAGE plpgsql SECURITY DEFINER;
══════════════════════════════════════════════════════════ */

const ADMIN_PWD = 'adrianne2025'; // ← change ce mot de passe
const SB_URL    = 'https://gnpjilwdehxsafdqdtak.supabase.co';
const SB_KEY    = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImducGppbHdkZWh4c2FmZHFkdGFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Nzk3NjIsImV4cCI6MjA5NTU1NTc2Mn0.iFYR9r5ZZsKcc9n2N8jPtFTLs0QDTIqR3KMCMhCdSdA';
const sb = createClient(SB_URL, SB_KEY);

// ── Auth ─────────────────────────────────────────────────
const lock  = document.getElementById('lock');
const admin = document.getElementById('admin');
const pwdInput = document.getElementById('pwd');
const pwdErr   = document.getElementById('pwd-err');

function unlock() {
  if (pwdInput.value === ADMIN_PWD) {
    sessionStorage.setItem('adr-auth', '1');
    lock.style.display = 'none'; admin.style.display = 'block';
    loadPrints();
  } else { pwdErr.textContent = 'Mot de passe incorrect.'; pwdInput.value = ''; }
}
if (sessionStorage.getItem('adr-auth') === '1') {
  lock.style.display = 'none'; admin.style.display = 'block'; loadPrints();
}
document.getElementById('pwd-btn').addEventListener('click', unlock);
pwdInput.addEventListener('keydown', e => e.key === 'Enter' && unlock());
document.getElementById('logout').addEventListener('click', () => { sessionStorage.removeItem('adr-auth'); location.reload(); });

// ── Modal ────────────────────────────────────────────────
const overlay   = document.getElementById('modal-overlay');
const modalTitle= document.getElementById('modal-title');
const form      = document.getElementById('print-form');
let selectedFiles    = [];
let existingPhotoUrls = [];
let editingId        = null;

function openModal(print = null) {
  editingId = print?.id || null;
  modalTitle.textContent = print ? 'Modifier la création' : 'Nouvelle création';
  document.getElementById('f-name').value     = print?.name || '';
  document.getElementById('f-cat').value      = print?.category || '';
  document.getElementById('f-desc').value     = print?.description || '';
  document.getElementById('f-price').value    = print?.price_range || '';
  document.getElementById('f-price-sell').value = print?.price_cents ? (print.price_cents / 100).toFixed(2) : '';
  document.getElementById('f-featured').checked = print?.featured || false;
  selectedFiles = [];
  existingPhotoUrls = print?.photo_urls?.length
    ? [...print.photo_urls]
    : (print?.photo_url ? [print.photo_url] : []);
  renderPhotoPreviews();
  overlay.style.display = 'flex';
}
function closeModal() { overlay.style.display = 'none'; selectedFiles = []; existingPhotoUrls = []; }

function renderPhotoPreviews() {
  const container = document.getElementById('photos-preview');
  const dropInner = document.getElementById('drop-inner');
  container.innerHTML = '';
  const total = existingPhotoUrls.length + selectedFiles.length;

  existingPhotoUrls.forEach((url, i) => {
    const thumb = document.createElement('div');
    thumb.className = 'photo-thumb';
    thumb.innerHTML = `<img src="${url}" alt="Photo ${i+1}" /><button type="button" class="photo-thumb-remove" data-type="existing" data-index="${i}">×</button>`;
    container.appendChild(thumb);
  });
  selectedFiles.forEach((file, i) => {
    const url = URL.createObjectURL(file);
    const thumb = document.createElement('div');
    thumb.className = 'photo-thumb photo-thumb-new';
    thumb.innerHTML = `<img src="${url}" alt="Nouvelle photo" /><button type="button" class="photo-thumb-remove" data-type="new" data-index="${i}">×</button>`;
    container.appendChild(thumb);
  });
  container.querySelectorAll('.photo-thumb-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.index);
      if (btn.dataset.type === 'existing') existingPhotoUrls.splice(idx, 1);
      else selectedFiles.splice(idx, 1);
      renderPhotoPreviews();
    });
  });

  container.style.display = total > 0 ? 'flex' : 'none';
  dropInner.style.display = total > 0 ? 'none' : 'flex';
}
document.getElementById('open-add').addEventListener('click', () => openModal());
document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('cancel-btn').addEventListener('click', closeModal);
overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });

// ── File upload ──────────────────────────────────────────
const fileInput = document.getElementById('file-input');
const dropZone  = document.getElementById('drop-zone');

fileInput.addEventListener('change', e => { Array.from(e.target.files).forEach(f => handleFile(f)); fileInput.value = ''; });
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); Array.from(e.dataTransfer.files).forEach(f => handleFile(f)); });

function handleFile(file) {
  if (!file || !file.type.startsWith('image/')) return;
  if (file.size > 5 * 1024 * 1024) { alert('Image trop grande. Max 5 Mo.'); return; }
  selectedFiles.push(file);
  renderPhotoPreviews();
}

async function uploadAllPhotos(files) {
  const prog = document.getElementById('upload-progress');
  const bar  = document.getElementById('progress-bar');
  const lbl  = document.getElementById('progress-label');
  prog.style.display = 'flex';
  const urls = [];
  for (let i = 0; i < files.length; i++) {
    bar.style.width = `${Math.round((i / files.length) * 100)}%`;
    lbl.textContent = `${i + 1} / ${files.length}…`;
    const file = files[i];
    const ext  = file.name.split('.').pop().toLowerCase();
    const name = `${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
    const { error } = await sb.storage.from('adrianne-prints').upload(name, file, { contentType: file.type });
    if (error) { prog.style.display = 'none'; throw error; }
    const { data: { publicUrl } } = sb.storage.from('adrianne-prints').getPublicUrl(name);
    urls.push(publicUrl);
  }
  bar.style.width = '100%'; lbl.textContent = '100%';
  setTimeout(() => { prog.style.display = 'none'; }, 600);
  return urls;
}

// ── Save ─────────────────────────────────────────────────
form.addEventListener('submit', async e => {
  e.preventDefault();
  const saveBtn  = document.getElementById('save-btn');
  const saveText = document.getElementById('save-text');
  saveBtn.disabled = true; saveText.textContent = 'Enregistrement…';

  try {
    const newUrls = selectedFiles.length > 0 ? await uploadAllPhotos(selectedFiles) : [];
    const allUrls = [...existingPhotoUrls, ...newUrls];

    const sellRaw = parseFloat(document.getElementById('f-price-sell').value);
    const priceCents = sellRaw >= 0.50 ? Math.round(sellRaw * 100) : null;

    const payload = {
      name:        document.getElementById('f-name').value.trim(),
      category:    document.getElementById('f-cat').value,
      description: document.getElementById('f-desc').value.trim(),
      price_range: document.getElementById('f-price').value.trim(),
      price_cents: priceCents,
      featured:    document.getElementById('f-featured').checked,
      photo_url:   allUrls[0] || '',
      photo_urls:  allUrls,
    };

    if (editingId) {
      await sb.from('adrianne_prints').update(payload).eq('id', editingId);
    } else {
      await sb.from('adrianne_prints').insert(payload);
    }

    closeModal(); loadPrints();
  } catch (err) { alert('Erreur : ' + err.message); }
  finally { saveBtn.disabled = false; saveText.textContent = 'Enregistrer'; }
});

// ── Visites journalières ──────────────────────────────────
async function loadDailyVisit() {
  const today = new Date().toISOString().split('T')[0];
  const { data } = await sb.from('daily_visits').select('count').eq('date', today).maybeSingle();
  const chip = document.getElementById('visit-chip');
  if (chip) {
    const n = data?.count || 0;
    chip.innerHTML = `<span>${n}</span> visite${n !== 1 ? 's' : ''} aujourd'hui`;
  }
}

// ── Load & render ─────────────────────────────────────────
async function loadPrints() {
  const { data: prints } = await sb.from('adrianne_prints').select('*').order('created_at', { ascending: false });
  const list  = document.getElementById('prints-list');
  const empty = document.getElementById('list-empty');
  const stats = document.getElementById('admin-stats');

  // Stats
  const total    = prints?.length || 0;
  const featured = prints?.filter(p => p.featured).length || 0;
  const cats     = [...new Set((prints||[]).map(p => p.category))].length;
  stats.innerHTML = `
    <div class="stat-chip"><span>${total}</span> création${total !== 1 ? 's' : ''}</div>
    <div class="stat-chip"><span>${featured}</span> coup${featured !== 1 ? 's' : ''} de cœur</div>
    <div class="stat-chip"><span>${cats}</span> catégorie${cats !== 1 ? 's' : ''}</div>
    <div class="stat-chip" id="visit-chip"><span>…</span> visites aujourd'hui</div>`;
  loadDailyVisit();

  if (!prints?.length) { list.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  list.innerHTML = '';
  prints.forEach(p => {
    const row = document.createElement('div');
    row.className = 'print-row';
    const photoCount = p.photo_urls?.length || (p.photo_url ? 1 : 0);
    row.innerHTML = `
      <div class="pr-photo">
        ${p.photo_url ? `<img src="${p.photo_url}" alt="${p.name}" />` : `<div class="pr-no-photo">📷</div>`}
        ${photoCount > 1 ? `<span class="pr-photo-count">${photoCount}</span>` : ''}
      </div>
      <div class="pr-info">
        <div class="pr-top">
          <span class="pr-name">${p.name}</span>
          ${p.featured ? '<span class="pr-star">⭐</span>' : ''}
        </div>
        <span class="pr-meta">${p.category}${p.price_range ? ' · ' + p.price_range : ''}</span>
        ${p.description ? `<p class="pr-desc">${p.description}</p>` : ''}
      </div>
      <div class="pr-actions">
        <button class="action-btn edit-btn" data-id="${p.id}">✏️ Modifier</button>
        <button class="action-btn del-btn" data-id="${p.id}">🗑️ Supprimer</button>
      </div>`;
    list.appendChild(row);
  });

  // Éditer
  list.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { data } = await sb.from('adrianne_prints').select('*').eq('id', btn.dataset.id).single();
      openModal(data);
    });
  });

  // Supprimer
  list.querySelectorAll('.del-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer cette création ?')) return;
      await sb.from('adrianne_prints').delete().eq('id', btn.dataset.id);
      loadPrints();
    });
  });
}

// ── Tabs ──────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
    btn.classList.add('active');
    document.getElementById(`tab-${btn.dataset.tab}`).style.display = 'block';
    if (btn.dataset.tab === 'commandes') loadOrders();
    if (btn.dataset.tab === 'realisations') loadRealisations();
  });
});

// ── Réalisations ──────────────────────────────────────────
const realOverlay = document.getElementById('real-modal-overlay');
let realSelectedFiles = [];
let realExistingUrls  = [];
let editingRealId     = null;

function openRealModal(item = null) {
  editingRealId = item?.id || null;
  document.getElementById('real-modal-title').textContent = item ? 'Modifier la réalisation' : 'Nouvelle réalisation';
  document.getElementById('r-name').value     = item?.name || '';
  document.getElementById('r-cat').value      = item?.category || '';
  document.getElementById('r-desc').value     = item?.description || '';
  document.getElementById('r-featured').checked = item?.featured || false;
  realSelectedFiles = [];
  realExistingUrls  = item?.photo_urls?.length
    ? [...item.photo_urls]
    : (item?.photo_url ? [item.photo_url] : []);
  renderRealPreviews();
  realOverlay.style.display = 'flex';
}
function closeRealModal() { realOverlay.style.display = 'none'; realSelectedFiles = []; realExistingUrls = []; }

function renderRealPreviews() {
  const container = document.getElementById('real-photos-preview');
  const dropInner = document.getElementById('real-drop-inner');
  container.innerHTML = '';
  const total = realExistingUrls.length + realSelectedFiles.length;

  realExistingUrls.forEach((url, i) => {
    const thumb = document.createElement('div');
    thumb.className = 'photo-thumb';
    thumb.innerHTML = `<img src="${url}" alt="Photo ${i+1}" /><button type="button" class="photo-thumb-remove" data-type="existing" data-index="${i}">×</button>`;
    container.appendChild(thumb);
  });
  realSelectedFiles.forEach((file, i) => {
    const url = URL.createObjectURL(file);
    const thumb = document.createElement('div');
    thumb.className = 'photo-thumb photo-thumb-new';
    thumb.innerHTML = `<img src="${url}" alt="Nouvelle photo" /><button type="button" class="photo-thumb-remove" data-type="new" data-index="${i}">×</button>`;
    container.appendChild(thumb);
  });
  container.querySelectorAll('.photo-thumb-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.index);
      if (btn.dataset.type === 'existing') realExistingUrls.splice(idx, 1);
      else realSelectedFiles.splice(idx, 1);
      renderRealPreviews();
    });
  });
  container.style.display = total > 0 ? 'flex' : 'none';
  dropInner.style.display  = total > 0 ? 'none' : 'flex';
}

document.getElementById('open-real').addEventListener('click', () => openRealModal());
document.getElementById('real-modal-close').addEventListener('click', closeRealModal);
document.getElementById('real-cancel-btn').addEventListener('click', closeRealModal);
realOverlay.addEventListener('click', e => { if (e.target === realOverlay) closeRealModal(); });

const realFileInput = document.getElementById('real-file-input');
const realDropZone  = document.getElementById('real-drop-zone');

realFileInput.addEventListener('change', e => { Array.from(e.target.files).forEach(f => handleRealFile(f)); realFileInput.value = ''; });
realDropZone.addEventListener('dragover', e => { e.preventDefault(); realDropZone.classList.add('drag-over'); });
realDropZone.addEventListener('dragleave', () => realDropZone.classList.remove('drag-over'));
realDropZone.addEventListener('drop', e => { e.preventDefault(); realDropZone.classList.remove('drag-over'); Array.from(e.dataTransfer.files).forEach(f => handleRealFile(f)); });

function handleRealFile(file) {
  if (!file || !file.type.startsWith('image/')) return;
  if (file.size > 5 * 1024 * 1024) { alert('Image trop grande. Max 5 Mo.'); return; }
  realSelectedFiles.push(file);
  renderRealPreviews();
}

document.getElementById('real-form').addEventListener('submit', async e => {
  e.preventDefault();
  const saveBtn  = document.getElementById('real-save-btn');
  const saveText = document.getElementById('real-save-text');
  saveBtn.disabled = true; saveText.textContent = 'Enregistrement…';

  try {
    const prog = document.getElementById('real-upload-progress');
    const bar  = document.getElementById('real-progress-bar');
    const lbl  = document.getElementById('real-progress-label');
    let newUrls = [];
    if (realSelectedFiles.length > 0) {
      prog.style.display = 'flex';
      for (let i = 0; i < realSelectedFiles.length; i++) {
        bar.style.width = `${Math.round((i / realSelectedFiles.length) * 100)}%`;
        lbl.textContent = `${i + 1} / ${realSelectedFiles.length}…`;
        const file = realSelectedFiles[i];
        const ext  = file.name.split('.').pop().toLowerCase();
        const name = `real-${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
        const { error } = await sb.storage.from('adrianne-prints').upload(name, file, { contentType: file.type });
        if (error) { prog.style.display = 'none'; throw error; }
        const { data: { publicUrl } } = sb.storage.from('adrianne-prints').getPublicUrl(name);
        newUrls.push(publicUrl);
      }
      bar.style.width = '100%'; lbl.textContent = '100%';
      setTimeout(() => { prog.style.display = 'none'; }, 600);
    }

    const allUrls = [...realExistingUrls, ...newUrls];
    const payload = {
      name:        document.getElementById('r-name').value.trim(),
      category:    document.getElementById('r-cat').value,
      description: document.getElementById('r-desc').value.trim(),
      featured:    document.getElementById('r-featured').checked,
      photo_url:   allUrls[0] || '',
      photo_urls:  allUrls,
    };

    if (editingRealId) {
      await sb.from('adrianne_realisations').update(payload).eq('id', editingRealId);
    } else {
      await sb.from('adrianne_realisations').insert(payload);
    }

    closeRealModal(); loadRealisations();
  } catch (err) { alert('Erreur : ' + err.message); }
  finally { saveBtn.disabled = false; saveText.textContent = 'Enregistrer'; }
});

async function loadRealisations() {
  const { data: items } = await sb.from('adrianne_realisations').select('*').order('created_at', { ascending: false });
  const list  = document.getElementById('real-list');
  const empty = document.getElementById('real-empty');

  if (!items?.length) { list.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  list.innerHTML = '';

  items.forEach(p => {
    const row = document.createElement('div');
    row.className = 'print-row';
    const photoCount = p.photo_urls?.length || (p.photo_url ? 1 : 0);
    row.innerHTML = `
      <div class="pr-photo">
        ${p.photo_url ? `<img src="${p.photo_url}" alt="${p.name}" />` : `<div class="pr-no-photo">🎨</div>`}
        ${photoCount > 1 ? `<span class="pr-photo-count">${photoCount}</span>` : ''}
      </div>
      <div class="pr-info">
        <div class="pr-top">
          <span class="pr-name">${p.name}</span>
          ${p.featured ? '<span class="pr-star">⭐</span>' : ''}
          <span class="real-tag">Non à vendre</span>
        </div>
        <span class="pr-meta">${p.category}</span>
        ${p.description ? `<p class="pr-desc">${p.description}</p>` : ''}
      </div>
      <div class="pr-actions">
        <button class="action-btn edit-real-btn" data-id="${p.id}">✏️ Modifier</button>
        <button class="action-btn del-real-btn" data-id="${p.id}">🗑️ Supprimer</button>
      </div>`;
    list.appendChild(row);
  });

  list.querySelectorAll('.edit-real-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { data } = await sb.from('adrianne_realisations').select('*').eq('id', btn.dataset.id).single();
      openRealModal(data);
    });
  });
  list.querySelectorAll('.del-real-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer cette réalisation ?')) return;
      await sb.from('adrianne_realisations').delete().eq('id', btn.dataset.id);
      loadRealisations();
    });
  });
}

// ── Commandes ─────────────────────────────────────────────
const orderOverlay = document.getElementById('order-modal-overlay');
let editingOrderId = null;

function openOrderModal(order = null) {
  editingOrderId = order?.id || null;
  document.getElementById('order-modal-title').textContent = order ? 'Modifier la commande' : 'Nouvelle commande';
  document.getElementById('o-edit-id').value   = order?.id || '';
  document.getElementById('o-num').value        = order?.order_number || '';
  document.getElementById('o-name').value       = order?.client_name || '';
  document.getElementById('o-desc').value       = order?.description || '';
  document.getElementById('o-status').value     = order?.status || 'en_attente';
  document.getElementById('o-days').value       = order?.estimated_days || 7;
  document.getElementById('o-notes').value      = order?.notes || '';
  // Auto-generate number for new orders
  if (!order) {
    const now = new Date();
    const pad = n => String(n).padStart(2, '0');
    document.getElementById('o-num').value = `ADR-${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}-${Math.floor(Math.random()*900)+100}`;
  }
  orderOverlay.style.display = 'flex';
}
function closeOrderModal() { orderOverlay.style.display = 'none'; }

document.getElementById('open-order').addEventListener('click', () => openOrderModal());
document.getElementById('order-modal-close').addEventListener('click', closeOrderModal);
document.getElementById('order-cancel').addEventListener('click', closeOrderModal);
orderOverlay.addEventListener('click', e => { if (e.target === orderOverlay) closeOrderModal(); });

document.getElementById('order-form').addEventListener('submit', async e => {
  e.preventDefault();
  const saveBtn = document.getElementById('order-save');
  saveBtn.disabled = true; saveBtn.textContent = 'Enregistrement…';

  const payload = {
    order_number:   document.getElementById('o-num').value.trim().toUpperCase(),
    client_name:    document.getElementById('o-name').value.trim(),
    description:    document.getElementById('o-desc').value.trim(),
    status:         document.getElementById('o-status').value,
    estimated_days: parseInt(document.getElementById('o-days').value),
    notes:          document.getElementById('o-notes').value.trim(),
    updated_at:     new Date().toISOString(),
  };

  try {
    if (editingOrderId) {
      await sb.from('adrianne_orders').update(payload).eq('id', editingOrderId);
    } else {
      await sb.from('adrianne_orders').insert(payload);
    }
    closeOrderModal(); loadOrders();
  } catch (err) { alert('Erreur : ' + err.message); }
  finally { saveBtn.disabled = false; saveBtn.textContent = 'Enregistrer'; }
});

const STATUS_INFO = {
  en_attente: { label: 'En attente',     color: '#64748b' },
  confirme:   { label: 'Confirmée',      color: '#2A5CB4' },
  impression: { label: 'En impression',  color: '#d97706' },
  finition:   { label: 'Finition',       color: '#7c3aed' },
  pret:       { label: 'Prête à livrer', color: '#059669' },
  livre:      { label: 'Livrée',         color: '#B5627A' },
};

async function loadOrders() {
  const { data: orders } = await sb.from('adrianne_orders').select('*').order('created_at', { ascending: false });
  const list  = document.getElementById('orders-list');
  const empty = document.getElementById('orders-empty');
  if (!orders?.length) { list.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  list.innerHTML = '';
  orders.forEach(o => {
    const info = STATUS_INFO[o.status] || { label: o.status, color: '#999' };
    const row = document.createElement('div');
    row.className = 'print-row';
    row.innerHTML = `
      <div class="order-icon">📦</div>
      <div class="pr-info">
        <div class="pr-top">
          <span class="pr-name">${o.order_number}</span>
          <span class="order-status-chip" style="background:${info.color}18;color:${info.color}">${info.label}</span>
        </div>
        <span class="pr-meta">${o.client_name} · ${o.description}</span>
        <div class="order-link-row">
          <a href="/suivi?num=${o.order_number}" target="_blank" class="order-track-link">🔗 Lien de suivi</a>
        </div>
      </div>
      <div class="pr-actions">
        <button class="action-btn edit-order-btn" data-id="${o.id}">✏️ Modifier</button>
        <button class="action-btn del-order-btn" data-id="${o.id}">🗑️ Supprimer</button>
      </div>`;
    list.appendChild(row);
  });

  list.querySelectorAll('.edit-order-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { data } = await sb.from('adrianne_orders').select('*').eq('id', btn.dataset.id).single();
      openOrderModal(data);
    });
  });
  list.querySelectorAll('.del-order-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer cette commande ?')) return;
      await sb.from('adrianne_orders').delete().eq('id', btn.dataset.id);
      loadOrders();
    });
  });
}
</script>

