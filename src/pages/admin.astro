let orderSelectedColors = new Set();

function createOrderSwatch(name, hex, container) {
  const btn = document.createElement('button');
  btn.type = 'button';
  btn.className = 'swatch-btn';
  btn.dataset.name = name;
  if (orderSelectedColors.has(name)) btn.classList.add('selected');
  btn.innerHTML = `
    <span class="swatch-circle" style="background:${hex || '#e8e8e8'}">
      <span class="swatch-check">✓</span>
    </span>
    <span class="swatch-label">${name}</span>
  `;
  btn.addEventListener('click', () => {
    if (name === 'Sans préférence') {
      const wasSelected = btn.classList.contains('selected');
      container.querySelectorAll('.swatch-btn').forEach(b => b.classList.remove('selected'));
      orderSelectedColors.clear();
      if (!wasSelected) { btn.classList.add('selected'); orderSelectedColors.add('Sans préférence'); }
    } else {
      container.querySelector('[data-name="Sans préférence"]')?.classList.remove('selected');
      orderSelectedColors.delete('Sans préférence');
      btn.classList.toggle('selected');
      if (btn.classList.contains('selected')) orderSelectedColors.add(name);
      else orderSelectedColors.delete(name);
    }
    document.getElementById('o-colors').value = orderSelectedColors.size > 0 ? [...orderSelectedColors].join(', ') : '';
  });
  return btn;
}

async function loadOrderSwatches(preselected = '') {
  orderSelectedColors = new Set(preselected ? preselected.split(', ').map(s => s.trim()).filter(Boolean) : []);
  const container = document.getElementById('o-color-swatches');
  container.innerHTML = '<span class="swatches-loading">Chargement…</span>';
  try {
    const { data: filaments } = await sb.from('adrianne_filaments').select('*').eq('is_available', true).order('filament_type').order('name');
    container.innerHTML = '';
    container.appendChild(createOrderSwatch('Sans préférence', '#e8e8e8', container));
    filaments?.forEach(f => container.appendChild(createOrderSwatch(f.name, f.hex_color, container)));
    document.getElementById('o-colors').value = preselected;
  } catch {
    container.innerHTML = '<span class="swatches-loading">Erreur de chargement</span>';
  }
}

