// ── Modal ────────────────────────────────────────────────
const overlay   = document.getElementById('modal-overlay');
const modalTitle= document.getElementById('modal-title');
const form      = document.getElementById('print-form');
let selectedFiles    = [];
let existingPhotoUrls = [];
let editingId        = null;

function openModal(print = null) {
  editingId = print?.id || null;
  modalTitle.textContent = print ? 'Modifier la création' : 'Nouvelle création';
  document.getElementById('f-name').value     = print?.name || '';
  document.getElementById('f-cat').value      = print?.category || '';
  document.getElementById('f-desc').value     = print?.description || '';
  document.getElementById('f-price').value    = print?.price_range || '';
  document.getElementById('f-price-sell').value = print?.price_cents ? (print.price_cents / 100).toFixed(2) : '';
  document.getElementById('f-featured').checked = print?.featured || false;
  selectedFiles = [];
  existingPhotoUrls = print?.photo_urls?.length
    ? [...print.photo_urls]
    : (print?.photo_url ? [print.photo_url] : []);
  renderPhotoPreviews();
  overlay.style.display = 'flex';
}
function closeModal() { overlay.style.display = 'none'; selectedFiles = []; existingPhotoUrls = []; }

function renderPhotoPreviews() {
  const container = document.getElementById('photos-preview');
  const dropInner = document.getElementById('drop-inner');
  container.innerHTML = '';
  const total = existingPhotoUrls.length + selectedFiles.length;

  existingPhotoUrls.forEach((url, i) => {
    const thumb = document.createElement('div');
    thumb.className = 'photo-thumb';
    thumb.innerHTML = `<img src="${url}" alt="Photo ${i+1}" /><button type="button" class="photo-thumb-remove" data-type="existing" data-index="${i}">×</button>`;
    container.appendChild(thumb);
  });
  selectedFiles.forEach((file, i) => {
    const url = URL.createObjectURL(file);
    const thumb = document.createElement('div');
    thumb.className = 'photo-thumb photo-thumb-new';
    thumb.innerHTML = `<img src="${url}" alt="Nouvelle photo" /><button type="button" class="photo-thumb-remove" data-type="new" data-index="${i}">×</button>`;
    container.appendChild(thumb);
  });
  container.querySelectorAll('.photo-thumb-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.index);
      if (btn.dataset.type === 'existing') existingPhotoUrls.splice(idx, 1);
      else selectedFiles.splice(idx, 1);
      renderPhotoPreviews();
    });
  });

  container.style.display = total > 0 ? 'flex' : 'none';
  dropInner.style.display = total > 0 ? 'none' : 'flex';
}
document.getElementById('open-add').addEventListener('click', () => openModal());
document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('cancel-btn').addEventListener('click', closeModal);
overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });

// ── File upload ──────────────────────────────────────────
const fileInput = document.getElementById('file-input');
const dropZone  = document.getElementById('drop-zone');

fileInput.addEventListener('change', e => { Array.from(e.target.files).forEach(f => handleFile(f)); fileInput.value = ''; });
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); Array.from(e.dataTransfer.files).forEach(f => handleFile(f)); });

function handleFile(file) {
  if (!file || !file.type.startsWith('image/')) return;
  if (file.size > 5 * 1024 * 1024) { alert('Image trop grande. Max 5 Mo.'); return; }
  selectedFiles.push(file);
  renderPhotoPreviews();
}

async function uploadAllPhotos(files) {
  const prog = document.getElementById('upload-progress');
  const bar  = document.getElementById('progress-bar');
  const lbl  = document.getElementById('progress-label');
  prog.style.display = 'flex';
  const urls = [];
  for (let i = 0; i < files.length; i++) {
    bar.style.width = `${Math.round((i / files.length) * 100)}%`;
    lbl.textContent = `${i + 1} / ${files.length}…`;
    const file = files[i];
    const ext  = file.name.split('.').pop().toLowerCase();
    const name = `${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
    const { error } = await sb.storage.from('adrianne-prints').upload(name, file, { contentType: file.type });
    if (error) { prog.style.display = 'none'; throw error; }
    const { data: { publicUrl } } = sb.storage.from('adrianne-prints').getPublicUrl(name);
    urls.push(publicUrl);
  }
  bar.style.width = '100%'; lbl.textContent = '100%';
  setTimeout(() => { prog.style.display = 'none'; }, 600);
  return urls;
}

// ── Save ─────────────────────────────────────────────────
form.addEventListener('submit', async e => {
  e.preventDefault();
  const saveBtn  = document.getElementById('save-btn');
  const saveText = document.getElementById('save-text');
  saveBtn.disabled = true; saveText.textContent = 'Enregistrement…';

  try {
    const newUrls = selectedFiles.length > 0 ? await uploadAllPhotos(selectedFiles) : [];
    const allUrls = [...existingPhotoUrls, ...newUrls];

    const sellRaw = parseFloat(document.getElementById('f-price-sell').value);
    const priceCents = sellRaw >= 0.50 ? Math.round(sellRaw * 100) : null;

    const payload = {
      name:        document.getElementById('f-name').value.trim(),
      category:    document.getElementById('f-cat').value,
      description: document.getElementById('f-desc').value.trim(),
      price_range: document.getElementById('f-price').value.trim(),
      price_cents: priceCents,
      featured:    document.getElementById('f-featured').checked,
      photo_url:   allUrls[0] || '',
      photo_urls:  allUrls,
    };

    if (editingId) {
      const { error: updateErr } = await sb.from('adrianne_prints').update(payload).eq('id', editingId);
      if (updateErr) throw updateErr;
    } else {
      const { error: insertErr } = await sb.from('adrianne_prints').insert(payload);
      if (insertErr) throw insertErr;
    }

    closeModal(); loadPrints();
  } catch (err) { alert('Erreur : ' + err.message); }
  finally { saveBtn.disabled = false; saveText.textContent = 'Enregistrer'; }
});

// ── Visites journalières ──────────────────────────────────
async function loadDailyVisit() {
  const today = new Date().toISOString().split('T')[0];
  const { data } = await sb.from('daily_visits').select('count').eq('date', today).maybeSingle();
  const chip = document.getElementById('visit-chip');
  if (chip) {
    const n = data?.count || 0;
    chip.innerHTML = `<span>${n}</span> visite${n !== 1 ? 's' : ''} aujourd'hui`;
  }
}

// ── Load & render ─────────────────────────────────────────
async function loadPrints() {
  const { data: prints } = await sb.from('adrianne_prints').select('*').order('created_at', { ascending: false });
  const list  = document.getElementById('prints-list');
  const empty = document.getElementById('list-empty');
  const stats = document.getElementById('admin-stats');

  // Stats
  const total    = prints?.length || 0;
  const featured = prints?.filter(p => p.featured).length || 0;
  const cats     = [...new Set((prints||[]).map(p => p.category))].length;
  stats.innerHTML = `
    <div class="stat-chip"><span>${total}</span> création${total !== 1 ? 's' : ''}</div>
    <div class="stat-chip"><span>${featured}</span> coup${featured !== 1 ? 's' : ''} de cœur</div>
    <div class="stat-chip"><span>${cats}</span> catégorie${cats !== 1 ? 's' : ''}</div>
    <div class="stat-chip" id="visit-chip"><span>…</span> visites aujourd'hui</div>`;
  loadDailyVisit();

  if (!prints?.length) { list.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  list.innerHTML = '';
  prints.forEach(p => {
    const row = document.createElement('div');
    row.className = 'print-row';
    const photoCount = p.photo_urls?.length || (p.photo_url ? 1 : 0);
    row.innerHTML = `
      <div class="pr-photo">
        ${p.photo_url ? `<img src="${p.photo_url}" alt="${p.name}" />` : `<div class="pr-no-photo">📷</div>`}
        ${photoCount > 1 ? `<span class="pr-photo-count">${photoCount}</span>` : ''}
      </div>
      <div class="pr-info">
        <div class="pr-top">
          <span class="pr-name">${p.name}</span>
          ${p.featured ? '<span class="pr-star">⭐</span>' : ''}
        </div>
        <span class="pr-meta">${p.category}${p.price_range ? ' · ' + p.price_range : ''}</span>
        ${p.price_cents
          ? `<span class="pr-stripe-chip">💳 ${(p.price_cents / 100).toFixed(2)} $</span>`
          : `<span class="pr-no-stripe">Pas de vente directe</span>`}
        ${p.description ? `<p class="pr-desc">${p.description}</p>` : ''}
      </div>
      <div class="pr-actions">
        <button class="action-btn edit-btn" data-id="${p.id}">✏️ Modifier</button>
        <button class="action-btn del-btn" data-id="${p.id}">🗑️ Supprimer</button>
      </div>`;
    list.appendChild(row);
  });

  // Éditer
  list.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { data } = await sb.from('adrianne_prints').select('*').eq('id', btn.dataset.id).single();
      openModal(data);
    });
  });

  // Supprimer
  list.querySelectorAll('.del-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer cette création ?')) return;
      await sb.from('adrianne_prints').delete().eq('id', btn.dataset.id);
      loadPrints();
    });
  });
}

// ── Tabs ──────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
