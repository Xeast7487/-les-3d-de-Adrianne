});

function renderInvItems() {
  const el = document.getElementById('inv-items-rows'); if (!el) return;
  el.innerHTML = invItems.map((item, i) => `
    <div class="inv-item-row">
      <input type="text" placeholder="Description du service" value="${item.desc.replace(/"/g,'&quot;')}" onchange="updateInvItem(${i},'desc',this.value)" />
      <input type="number" min="1" value="${item.qty}" onchange="updateInvItem(${i},'qty',+this.value)" />
      <input type="number" min="0" step="0.01" value="${item.price}" onchange="updateInvItem(${i},'price',+this.value)" placeholder="0.00" />
      <span class="inv-item-total">${fmtMoney(item.qty * item.price)}</span>
      <button type="button" onclick="removeInvItem(${i})" style="background:none;border:none;cursor:pointer;font-size:1.2rem;color:var(--text-2);padding:0 4px">×</button>
    </div>
  `).join('');
  calcInvTotals();
}

(window as any).updateInvItem = (i: number, key: string, val: any) => { (invItems[i] as any)[key] = val; renderInvItems(); };
(window as any).removeInvItem = (i: number) => { invItems.splice(i, 1); renderInvItems(); };

function calcInvTotals() {
  const sub      = invItems.reduce((s, it) => s + it.qty * it.price, 0);
  const applyTps = (document.getElementById('inv-apply-tps') as HTMLInputElement)?.checked;
  const applyTvq = (document.getElementById('inv-apply-tvq') as HTMLInputElement)?.checked;
  const tps      = applyTps ? sub * 0.05 : 0;
  const tvq      = applyTvq ? sub * 0.09975 : 0;
  const total    = sub + tps + tvq;
  const set = (id: string, v: string) => { const e = document.getElementById(id); if (e) e.textContent = v; };
  set('inv-disp-subtotal', fmtMoney(sub));
  set('inv-disp-tps',      fmtMoney(tps));
  set('inv-disp-tvq',      fmtMoney(tvq));
  set('inv-disp-total',    fmtMoney(total));
  const rt = document.getElementById('inv-row-tps'); if (rt) rt.style.opacity = applyTps ? '1' : '0.35';
  const rv = document.getElementById('inv-row-tvq'); if (rv) rv.style.opacity = applyTvq ? '1' : '0.35';
  return { sub, tps, tvq, total, applyTps, applyTvq };
}
document.getElementById('inv-apply-tps')?.addEventListener('change', calcInvTotals);
document.getElementById('inv-apply-tvq')?.addEventListener('change', calcInvTotals);

document.getElementById('invoice-form')?.addEventListener('submit', async e => {
  e.preventDefault();
  const saveBtn = document.getElementById('invoice-save') as HTMLButtonElement;
  saveBtn.disabled = true; saveBtn.textContent = 'Enregistrement…';
  const editId = (document.getElementById('inv-edit-id') as HTMLInputElement).value;
  const { sub, tps, tvq, total, applyTps, applyTvq } = calcInvTotals();
  const payload = {
    client_id:      (document.getElementById('inv-client') as HTMLSelectElement).value,
    invoice_number: (document.getElementById('inv-number') as HTMLInputElement).value.trim(),
    title:          (document.getElementById('inv-title')  as HTMLInputElement).value.trim(),
    items:          invItems,
    subtotal:       Math.round(sub   * 100) / 100,
    tax_rate:       applyTps ? 5 : 0,
    tax:            Math.round((tps + tvq) * 100) / 100,
    apply_tps:      applyTps,
    apply_tvq:      applyTvq,
    tps_amount:     Math.round(tps   * 100) / 100,
    tvq_amount:     Math.round(tvq   * 100) / 100,
    total:          Math.round(total * 100) / 100,
    status:         (document.getElementById('inv-status') as HTMLSelectElement).value,
    due_date:       (document.getElementById('inv-due')    as HTMLInputElement).value || null,
    notes:          (document.getElementById('inv-notes')  as HTMLTextAreaElement).value.trim(),
  };
  try {
    if (editId) await sb.from('adrianne_invoices').update(payload).eq('id', editId);
    else        await sb.from('adrianne_invoices').insert(payload);
    closeInvoiceModal(); await loadInvoices();
  } catch (err: any) { alert('Erreur : ' + err.message); }
  finally { saveBtn.disabled = false; saveBtn.textContent = 'Enregistrer la facture'; }
});

async function loadInvoices() {
  const { data } = await sb.from('adrianne_invoices').select('*, adrianne_clients(name, company)').order('created_at', { ascending: false });
  const list  = document.getElementById('invoices-list');
  const empty = document.getElementById('invoices-empty');
  const stats = document.getElementById('invoices-stats');
  if (!list) return;
  const invs = data || [];
  const pending = invs.filter((i: any) => i.status === 'pending').reduce((s: number, i: any) => s + parseFloat(i.total), 0);
  const paid    = invs.filter((i: any) => i.status === 'paid').reduce((s: number, i: any) => s + parseFloat(i.total), 0);
  if (stats) stats.innerHTML = `
    <div class="stat-chip"><span>${invs.length}</span> facture${invs.length !== 1 ? 's' : ''}</div>
    <div class="stat-chip"><span>${fmtMoney(pending)}</span> en attente</div>
    <div class="stat-chip"><span>${fmtMoney(paid)}</span> encaissé</div>`;
  if (!invs.length) { list.innerHTML = ''; if (empty) empty.style.display = 'block'; return; }
  if (empty) empty.style.display = 'none';
  list.innerHTML = '';
  invs.forEach((inv: any) => {
    const client = inv.adrianne_clients;
    const statusColors: Record<string,string> = { pending:'#d97706', paid:'#059669', overdue:'#dc2626', cancelled:'#6b7280' };
    const color = statusColors[inv.status] || '#999';
    const row = document.createElement('div');
    row.className = 'print-row';
    row.innerHTML = `
      <div class="order-icon">🧾</div>
      <div class="pr-info" style="min-width:0">
        <div class="pr-top">
          <span class="pr-name">${inv.invoice_number}</span>
          <span class="order-status-chip" style="background:${color}18;color:${color}">${INV_STATUS[inv.status] || inv.status}</span>
        </div>
        <span class="pr-meta">${inv.title}${client ? ' · ' + client.name : ''}</span>
      </div>
      <div style="font-weight:700;font-size:0.95rem;color:var(--text);flex-shrink:0;font-family:'Cormorant Garamond',serif">${fmtMoney(parseFloat(inv.total))}</div>
      <div class="pr-actions">
        <button class="action-btn edit-inv-btn" data-id="${inv.id}">✏️ Modifier</button>
        <button class="action-btn toggle-paid-btn" data-id="${inv.id}" data-status="${inv.status}">${inv.status === 'paid' ? '↩ Annuler' : '✅ Payée'}</button>
        <button class="action-btn del-inv-btn" data-id="${inv.id}">🗑️</button>
      </div>`;
    list.appendChild(row);
  });
  list.querySelectorAll('.edit-inv-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { data: inv } = await sb.from('adrianne_invoices').select('*').eq('id', (btn as HTMLElement).dataset.id).single();
      if (inv) { loadClientsForDropdown(); openInvoiceModal(inv); }
    });
  });
  list.querySelectorAll('.toggle-paid-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id      = (btn as HTMLElement).dataset.id;
      const current = (btn as HTMLElement).dataset.status;
      await sb.from('adrianne_invoices').update({ status: current === 'paid' ? 'pending' : 'paid' }).eq('id', id);
      loadInvoices();
    });
  });
  list.querySelectorAll('.del-inv-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer cette facture ?')) return;
      await sb.from('adrianne_invoices').delete().eq('id', (btn as HTMLElement).dataset.id);
      loadInvoices();
    });
  });
}

async function loadFilaments() {
  const { data: items } = await sb.from('adrianne_filaments').select('*').order('filament_type').order('name');
  const grid  = document.getElementById('filaments-grid');
  const empty = document.getElementById('filaments-empty');
  if (!items?.length) { grid.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  grid.innerHTML = '';
  items.forEach(f => {
    const card = document.createElement('div');
    card.className = `fil-card${f.is_available ? '' : ' fil-unavail'}`;
    card.innerHTML = `
      <div class="fil-swatch" style="background:${f.hex_color}"></div>
      <div class="fil-info">
        <span class="fil-name">${f.name}</span>
        <span class="fil-type">${f.filament_type}</span>
      </div>
      <button class="toggle-avail-btn" data-id="${f.id}" data-avail="${f.is_available}" title="${f.is_available ? 'Désactiver' : 'Activer'}">
        ${f.is_available ? '✅' : '⏸️'}
      </button>
      <div class="fil-actions">
        <button class="action-btn edit-fil-btn" data-id="${f.id}">✏️</button>
        <button class="action-btn del-fil-btn" data-id="${f.id}">🗑️</button>
      </div>`;
    grid.appendChild(card);
  });
  grid.querySelectorAll('.toggle-avail-btn').forEach(btn => {
    btn.addEventListener('click', () => toggleFilAvail(btn.dataset.id, btn.dataset.avail === 'true'));
  });
  grid.querySelectorAll('.edit-fil-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { data } = await sb.from('adrianne_filaments').select('*').eq('id', btn.dataset.id).single();
      openFilModal(data);
    });
  });
  grid.querySelectorAll('.del-fil-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer ce filament ?')) return;
      await sb.from('adrianne_filaments').delete().eq('id', btn.dataset.id);
      loadFilaments();
    });
  });
}
</script>

<style>
  main { padding-top: 68px; min-height: 100vh; background: var(--bg); }

  /* Lock */
  #lock { min-height: calc(100vh - 68px); display: flex; align-items: center; justify-content: center; padding: 2rem; }
  .lock-card { background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 3rem 2.5rem; width: 100%; max-width: 380px; text-align: center; box-shadow: 0 8px 32px rgba(0,0,0,0.06); }
  .lock-logo { display: flex; justify-content: center; margin-bottom: 1.25rem; }
  .logo-a { width: 48px; height: 48px; border-radius: 50%; background: var(--accent); color: white; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.6rem; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .lock-card h2 { font-size: 1.4rem; margin-bottom: 0.4rem; }
  .lock-card > p { font-size: 0.875rem; color: var(--text-2); margin-bottom: 1.5rem; }
  .lock-card input { width: 100%; padding: 0.7rem 1rem; border: 1.5px solid var(--border); border-radius: 10px; font-size: 0.9rem; background: var(--bg); color: var(--text); font-family: 'Jost', sans-serif; outline: none; margin-bottom: 0.75rem; }
  .lock-card input:focus { border-color: var(--accent); }
  .lock-card .btn-primary { width: 100%; justify-content: center; font-family: 'Jost', sans-serif; cursor: pointer; border: none; }
  .err-msg { margin-top: 0.6rem; font-size: 0.8rem; color: #dc2626; min-height: 1rem; }

  /* Admin */
  .admin-wrap { max-width: 960px; margin: 0 auto; padding: 3rem 2rem 5rem; }
  .admin-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .admin-top h1 { font-size: 1.75rem; flex: 1; }
  .admin-sub { font-size: 0.825rem; color: var(--text-2); margin-top: 0.2rem; }
  .stats-row { display: flex; gap: 0.75rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .stat-chip { background: var(--white); border: 1px solid var(--border); border-radius: 999px; padding: 0.35rem 0.9rem; font-size: 0.8rem; color: var(--text-2); }
  .stat-chip span { font-weight: 700; color: var(--accent); }

  /* Buttons */
  .btn-primary { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--accent); color: var(--white); padding: 0.6rem 1.3rem; border-radius: 999px; font-size: 0.83rem; font-weight: 600; border: none; cursor: pointer; font-family: 'Jost', sans-serif; transition: background 0.2s; }
  .btn-primary:hover { background: var(--accent-d); }
  .btn-primary:disabled { opacity: 0.65; cursor: not-allowed; }
  .btn-outline { display: inline-flex; align-items: center; background: transparent; color: var(--text-2); padding: 0.6rem 1.3rem; border-radius: 999px; font-size: 0.83rem; font-weight: 500; border: 1.5px solid var(--border); cursor: pointer; font-family: 'Jost', sans-serif; transition: border-color 0.2s, color 0.2s; }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  /* Modal */
  .modal-overlay { position: fixed; inset: 0; background: rgba(26,23,20,0.5); backdrop-filter: blur(4px); z-index: 200; align-items: center; justify-content: center; padding: 1rem; }
  .modal { background: var(--white); border-radius: 20px; padding: 2rem; width: 100%; max-width: 580px; max-height: 92vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.15); }
  .modal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem; }
  .modal-head h3 { font-size: 1.25rem; }
  .modal-x { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-2); line-height: 1; padding: 0; }
  .modal-x:hover { color: var(--text); }
  .mform-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .mfield { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1.1rem; }
  .mfield label { font-size: 0.78rem; font-weight: 600; color: var(--text); letter-spacing: 0.02em; }
  .mfield input, .mfield select, .mfield textarea { background: var(--bg); border: 1.5px solid var(--border); color: var(--text); border-radius: 9px; padding: 0.6rem 0.85rem; font-size: 0.85rem; outline: none; font-family: 'Jost', sans-serif; width: 100%; transition: border-color 0.2s; }
  .mfield input:focus, .mfield select:focus, .mfield textarea:focus { border-color: var(--accent); }
  .mfield textarea { resize: vertical; min-height: 80px; }
  .mfield-check { justify-content: flex-end; }
  .check-lbl { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.82rem; color: var(--text-2); }
  .check-lbl input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; }
  .req { color: var(--accent); }
  .opt { font-weight: 400; color: var(--text-2); }

  /* Drop zone */
  .drop-zone { border: 2px dashed var(--border); border-radius: 12px; padding: 1.25rem; text-align: center; cursor: pointer; transition: border-color 0.2s; position: relative; background: var(--bg); }
  .drop-zone.drag-over { border-color: var(--accent); background: var(--accent-l); }
  #drop-inner { display: flex; flex-direction: column; align-items: center; gap: 0.4rem; }
  #drop-inner p { font-size: 0.82rem; color: var(--text-2); }
  .drop-hint { font-size: 0.72rem !important; color: rgba(26,23,20,0.3) !important; }
  .file-link { color: var(--accent); text-decoration: underline; cursor: pointer; }
  .progress-wrap { display: flex; align-items: center; gap: 0.75rem; margin-top: 0.5rem; }
  .progress-bar { flex: 1; height: 4px; background: var(--accent); border-radius: 2px; transition: width 0.3s; }
  #progress-label { font-size: 0.72rem; color: var(--text-2); flex-shrink: 0; }

  /* Multi-photo previews */
  .photos-preview { display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0.75rem 0 0; justify-content: center; }
  .photo-thumb { position: relative; width: 80px; height: 80px; border-radius: 8px; overflow: hidden; border: 2px solid var(--border); flex-shrink: 0; }
  .photo-thumb-new { border-color: var(--accent); }
  .photo-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .photo-thumb-remove { position: absolute; top: 2px; right: 2px; background: rgba(26,23,20,0.7); color: white; border: none; border-radius: 4px; width: 18px; height: 18px; font-size: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; padding: 0; font-family: 'Jost', sans-serif; }
  .photo-thumb-remove:hover { background: #dc2626; }
  .pr-photo { position: relative; }
  .pr-photo-count { position: absolute; bottom: 2px; right: 2px; background: rgba(26,23,20,0.75); color: white; font-size: 0.6rem; font-weight: 700; padding: 1px 5px; border-radius: 4px; }

  .modal-foot { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 0.5rem; }

  /* Prints list */
  .prints-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .print-row { background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 1rem 1.25rem; display: flex; align-items: center; gap: 1.25rem; transition: box-shadow 0.2s; }
  .print-row:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .pr-photo { width: 64px; height: 64px; border-radius: 10px; overflow: hidden; flex-shrink: 0; background: var(--bg2); display: flex; align-items: center; justify-content: center; }
  .pr-photo img { width: 100%; height: 100%; object-fit: cover; }
  .pr-no-photo { font-size: 1.4rem; opacity: 0.35; }
  .pr-info { flex: 1; min-width: 0; }
  .pr-top { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
  .pr-name { font-size: 0.95rem; font-weight: 600; font-family: 'Cormorant Garamond', serif; }
  .pr-star { font-size: 0.85rem; }
  .pr-meta { font-size: 0.75rem; color: var(--text-2); }
  .pr-desc { font-size: 0.78rem; color: var(--text-2); margin-top: 0.25rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pr-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
  .action-btn { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 0.4rem 0.75rem; font-size: 0.75rem; cursor: pointer; font-family: 'Jost', sans-serif; transition: border-color 0.2s, background 0.2s; }
  .action-btn:hover { background: var(--bg2); border-color: var(--accent); }
  .list-empty { text-align: center; padding: 4rem 2rem; color: var(--text-2); font-style: italic; background: var(--white); border: 1px dashed var(--border); border-radius: 16px; }

  /* Tabs */
  .admin-tabs { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem; flex-wrap: wrap; }
  .tab-btn { background: none; border: 1.5px solid var(--border); color: var(--text-2); padding: 0.5rem 1.1rem; border-radius: 999px; font-size: 0.83rem; font-weight: 500; cursor: pointer; font-family: 'Jost', sans-serif; transition: all 0.2s; }
  .tab-btn:hover { border-color: var(--accent); color: var(--accent); }
  .tab-btn.active { background: var(--accent); border-color: var(--accent); color: var(--white); }

  /* Orders */
  .order-icon { width: 48px; height: 48px; background: rgba(42,92,180,0.08); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
  .order-status-chip { font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px; letter-spacing: 0.03em; }
  .order-link-row { margin-top: 0.3rem; }
  .order-track-link { font-size: 0.75rem; color: var(--accent); font-weight: 500; transition: opacity 0.2s; }
  .order-track-link:hover { opacity: 0.7; }

  .real-tag { font-size: 0.62rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(13,27,46,0.07); color: var(--text-2); letter-spacing: 0.04em; }

  .pr-stripe-chip { display: inline-block; font-size: 0.68rem; font-weight: 700; padding: 0.15rem 0.55rem; border-radius: 999px; background: rgba(42,92,180,0.1); color: var(--accent); margin-top: 0.25rem; }
  .pr-no-stripe { display: inline-block; font-size: 0.68rem; color: rgba(13,27,46,0.35); margin-top: 0.25rem; font-style: italic; }
  .field-hint { font-size: 0.72rem; color: var(--text-2); margin-top: 0.2rem; line-height: 1.4; }
  .pr-colors { display: block; font-size: 0.72rem; color: var(--text-2); margin-top: 0.15rem; }

  /* Swatches couleurs commande — :global() requis (éléments créés en JS) */
  :global(#o-color-swatches .swatch-btn),
  :global(#order-modal-overlay .swatch-btn) { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; background: none; border: 2px solid var(--border); border-radius: 12px; padding: 0.55rem 0.5rem; cursor: pointer; transition: border-color 0.2s, transform 0.15s, background 0.2s; min-width: 60px; font-family: 'DM Sans', sans-serif; }
  :global(#o-color-swatches .swatch-btn:hover),
  :global(#order-modal-overlay .swatch-btn:hover) { border-color: var(--accent); transform: translateY(-1px); }
  :global(#o-color-swatches .swatch-btn.selected),
  :global(#order-modal-overlay .swatch-btn.selected) { border-color: var(--accent); background: rgba(42,92,180,0.07); }
  :global(#o-color-swatches .swatch-circle),
  :global(#order-modal-overlay .swatch-circle) { width: 28px; height: 28px; border-radius: 50%; border: 2px solid rgba(0,0,0,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  :global(#o-color-swatches .swatch-check),
  :global(#order-modal-overlay .swatch-check) { display: none; font-size: 0.7rem; font-weight: 700; color: white; text-shadow: 0 1px 3px rgba(0,0,0,0.5); }
  :global(#o-color-swatches .swatch-btn.selected .swatch-check),
  :global(#order-modal-overlay .swatch-btn.selected .swatch-check) { display: block; }
  :global(#o-color-swatches .swatch-label),
  :global(#order-modal-overlay .swatch-label) { font-size: 0.62rem; color: var(--text); text-align: center; line-height: 1.2; font-weight: 500; max-width: 54px; word-wrap: break-word; }
  .swatches-wrap { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.35rem; min-height: 60px; align-items: flex-start; align-content: flex-start; }
  .swatches-loading { font-size: 0.78rem; color: var(--text-2); font-style: italic; align-self: center; }

  /* Filaments */
  .filaments-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.75rem; }
  .fil-card { background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 0.85rem 1rem; display: flex; align-items: center; gap: 0.75rem; transition: box-shadow 0.2s; }
  .fil-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .fil-unavail { opacity: 0.5; }
  .fil-swatch { width: 42px; height: 42px; border-radius: 50%; border: 2px solid rgba(0,0,0,0.1); flex-shrink: 0; }
