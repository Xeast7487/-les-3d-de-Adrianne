---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Admin — Les 3D d'Adrianne">
  <Nav />
  <main>

    <!-- ─── Écran de connexion ──────────────────────────── -->
    <div id="lock">
      <div class="lock-card">
        <div class="lock-logo"><span class="logo-a">A</span></div>
        <h2>Espace admin</h2>
        <p>Entre ton mot de passe pour continuer</p>
        <input type="password" id="pwd" placeholder="Mot de passe" autofocus />
        <button id="pwd-btn" class="btn-primary">Accéder</button>
        <p id="pwd-err" class="err-msg"></p>
      </div>
    </div>

    <!-- ─── Interface admin ─────────────────────────────── -->
    <div id="admin" style="display:none">
      <div class="admin-wrap">

        <!-- Tabs -->
        <div class="admin-tabs">
          <button class="tab-btn active" data-tab="galerie">🖼️ Galerie</button>
          <button class="tab-btn" data-tab="realisations">🎨 Réalisations</button>
          <button class="tab-btn" data-tab="commandes">📦 Commandes</button>
          <button class="tab-btn" data-tab="filaments">🧵 Filaments</button>
          <button class="tab-btn" data-tab="clients">👤 Clients</button>
          <button class="tab-btn" data-tab="factures">🧾 Factures</button>
          <button id="logout" class="btn-outline" style="margin-left:auto">Déconnexion</button>
        </div>

        <!-- ═══ TAB GALERIE ═══ -->
        <div id="tab-galerie" class="tab-content">
        <div class="admin-top">
          <div>
            <h1>Mes créations</h1>
            <p class="admin-sub">Gère ta galerie directement ici</p>
          </div>
          <button id="open-add" class="btn-primary">+ Ajouter une création</button>
        </div>

        <!-- Stats rapides -->
        <div id="admin-stats" class="stats-row"></div>

        <!-- Modal ajout / édition -->
        <div id="modal-overlay" class="modal-overlay" style="display:none">
          <div class="modal">
            <div class="modal-head">
              <h3 id="modal-title">Nouvelle création</h3>
              <button id="modal-close" class="modal-x">×</button>
            </div>
            <form id="print-form">
              <input type="hidden" id="edit-id" />

              <div class="mform-row">
                <div class="mfield">
                  <label>Nom <span class="req">*</span></label>
                  <input type="text" id="f-name" placeholder="ex: Figurine Dragon" required />
                </div>
                <div class="mfield">
                  <label>Catégorie <span class="req">*</span></label>
                  <select id="f-cat" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option>Figurines</option>
                    <option>Déco</option>
                    <option>Utilitaires</option>
                    <option>Cadeaux</option>
                    <option>Divers</option>
                  </select>
                </div>
              </div>

              <div class="mfield">
                <label>Description <span class="opt">(optionnel)</span></label>
                <textarea id="f-desc" rows="3" placeholder="Décris brièvement la pièce…"></textarea>
              </div>

              <div class="mform-row">
                <div class="mfield">
                  <label>Prix affiché <span class="opt">(optionnel)</span></label>
                  <input type="text" id="f-price" placeholder="ex: 15 $ – 25 $" />
                </div>
                <div class="mfield">
                  <label>💳 Prix de vente Stripe $ <span class="req">*</span> <span class="opt">(active le bouton Acheter)</span></label>
                  <input type="number" id="f-price-sell" placeholder="ex: 14.99 pour 14,99 $" step="0.01" min="0.50" />
                  <p class="field-hint">Entre le prix en dollars (ex: 14.99). Laisser vide si l'item n'est pas à vendre directement.</p>
                </div>
              </div>

              <div class="mfield mfield-check" style="margin-top:-0.5rem">
                <label class="check-lbl">
                  <input type="checkbox" id="f-featured" />
                  <span>⭐ Mettre en avant (coup de cœur)</span>
                </label>
              </div>

              <!-- Upload photos -->
              <div class="mfield">
                <label>Photos <span class="opt">(plusieurs possibles)</span></label>
                <div id="drop-zone" class="drop-zone">
                  <div id="drop-inner">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>Glisse des photos ici ou <label for="file-input" class="file-link">clique pour choisir</label></p>
                    <p class="drop-hint">JPG, PNG, WEBP · Max 5 Mo par photo · Plusieurs photos possibles</p>
                  </div>
                  <div id="photos-preview" class="photos-preview" style="display:none"></div>
                </div>
                <input type="file" id="file-input" accept="image/*" multiple style="display:none" />
                <div id="upload-progress" style="display:none" class="progress-wrap">
                  <div id="progress-bar" class="progress-bar"></div>
                  <span id="progress-label">0%</span>
                </div>
              </div>

              <div class="modal-foot">
                <button type="button" id="cancel-btn" class="btn-outline">Annuler</button>
                <button type="submit" id="save-btn" class="btn-primary">
                  <span id="save-text">Enregistrer</span>
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Liste des créations -->
        <div id="prints-list" class="prints-list"></div>
        <div id="list-empty" style="display:none" class="list-empty">
          <p>Aucune création pour l'instant. Clique sur « Ajouter une création » pour commencer !</p>
        </div>
        </div><!-- fin tab-galerie -->

        <!-- ═══ TAB RÉALISATIONS ═══ -->
        <div id="tab-realisations" class="tab-content" style="display:none">
        <div class="admin-top">
          <div>
            <h1>Réalisations</h1>
            <p class="admin-sub">Photos de tes créations passées — non disponibles à la vente</p>
          </div>
          <button id="open-real" class="btn-primary">+ Ajouter une réalisation</button>
        </div>

        <!-- Modal réalisation -->
        <div id="real-modal-overlay" class="modal-overlay" style="display:none">
          <div class="modal">
            <div class="modal-head">
              <h3 id="real-modal-title">Nouvelle réalisation</h3>
              <button id="real-modal-close" class="modal-x">×</button>
            </div>
            <form id="real-form">
              <input type="hidden" id="r-edit-id" />

              <div class="mform-row">
                <div class="mfield">
                  <label>Nom <span class="req">*</span></label>
                  <input type="text" id="r-name" placeholder="ex: Figurine Dragon Blanc" required />
                </div>
                <div class="mfield">
                  <label>Catégorie <span class="req">*</span></label>
                  <select id="r-cat" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option>Figurines</option>
                    <option>Déco</option>
                    <option>Utilitaires</option>
                    <option>Cadeaux</option>
                    <option>Divers</option>
                  </select>
                </div>
              </div>

              <div class="mfield">
                <label>Description <span class="opt">(optionnel)</span></label>
                <textarea id="r-desc" rows="3" placeholder="Décris la pièce, le contexte, le matériau utilisé…"></textarea>
              </div>

              <div class="mfield mfield-check">
                <label class="check-lbl">
                  <input type="checkbox" id="r-featured" />
                  <span>⭐ Mettre en avant (coup de cœur)</span>
                </label>
              </div>

              <!-- Upload photos -->
              <div class="mfield">
                <label>Photos <span class="opt">(plusieurs possibles)</span></label>
                <div id="real-drop-zone" class="drop-zone">
                  <div id="real-drop-inner">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>Glisse des photos ici ou <label for="real-file-input" class="file-link">clique pour choisir</label></p>
                    <p class="drop-hint">JPG, PNG, WEBP · Max 5 Mo par photo · Plusieurs photos possibles</p>
                  </div>
                  <div id="real-photos-preview" class="photos-preview" style="display:none"></div>
                </div>
                <input type="file" id="real-file-input" accept="image/*" multiple style="display:none" />
                <div id="real-upload-progress" style="display:none" class="progress-wrap">
                  <div id="real-progress-bar" class="progress-bar"></div>
                  <span id="real-progress-label">0%</span>
                </div>
              </div>

              <div class="modal-foot">
                <button type="button" id="real-cancel-btn" class="btn-outline">Annuler</button>
                <button type="submit" id="real-save-btn" class="btn-primary">
                  <span id="real-save-text">Enregistrer</span>
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Liste des réalisations -->
        <div id="real-list" class="prints-list"></div>
        <div id="real-empty" style="display:none" class="list-empty">
          <p>Aucune réalisation pour l'instant. Clique sur « Ajouter une réalisation » pour commencer !</p>
        </div>
        </div><!-- fin tab-realisations -->

        <!-- ═══ TAB COMMANDES ═══ -->
        <div id="tab-commandes" class="tab-content" style="display:none">
          <div class="admin-top">
            <div>
              <h1>Commandes</h1>
              <p class="admin-sub">Crée et gère le suivi des commandes de tes clients</p>
            </div>
            <button id="open-order" class="btn-primary">+ Nouvelle commande</button>
          </div>

          <!-- Modal commande -->
          <div id="order-modal-overlay" class="modal-overlay" style="display:none">
            <div class="modal">
              <div class="modal-head">
                <h3 id="order-modal-title">Nouvelle commande</h3>
                <button id="order-modal-close" class="modal-x">×</button>
              </div>
              <form id="order-form">
                <input type="hidden" id="o-edit-id" />
                <div class="mform-row">
                  <div class="mfield">
                    <label>Numéro de commande <span class="req">*</span></label>
                    <input type="text" id="o-num" placeholder="ex: ADR-001" required />
                  </div>
                  <div class="mfield">
                    <label>Nom du client <span class="req">*</span></label>
                    <input type="text" id="o-name" placeholder="Marie Tremblay" required />
                  </div>
                </div>
                <div class="mfield">
                  <label>Description de la commande <span class="req">*</span></label>
                  <textarea id="o-desc" rows="2" placeholder="ex: Figurine Dragon blanc 15cm" required></textarea>
                </div>
                <div class="mfield">
                  <label>Couleur(s) de filament <span class="opt">(optionnel)</span></label>
                  <input type="hidden" id="o-colors" />
                  <div id="o-color-swatches" class="swatches-wrap">
                    <span class="swatches-loading">Chargement des couleurs…</span>
                  </div>
                </div>
                <div class="mform-row">
                  <div class="mfield">
                    <label>Statut <span class="req">*</span></label>
                    <select id="o-status" required>
                      <option value="en_attente">📋 En attente</option>
                      <option value="confirme">✅ Confirmée</option>
                      <option value="impression">🖨️ En impression</option>
                      <option value="finition">✨ Finition</option>
                      <option value="pret">📦 Prête à livrer</option>
                      <option value="livre">🎉 Livrée</option>
                    </select>
                  </div>
                  <div class="mfield">
                    <label>Délai estimé (jours) <span class="req">*</span></label>
                    <input type="number" id="o-days" value="7" min="1" max="60" required />
                  </div>
                </div>
                <div class="mfield">
                  <label>Message pour le client <span class="opt">(optionnel)</span></label>
                  <textarea id="o-notes" rows="2" placeholder="ex: Votre commande est en cours, livraison prévue vendredi !"></textarea>
                </div>
                <div class="mform-row">
                  <div class="mfield">
                    <label>Courriel du client <span class="opt">(optionnel)</span></label>
                    <input type="email" id="o-email" placeholder="client@exemple.com" />
                  </div>
                  <div class="mfield">
                    <label>Montant total ($) <span class="opt">(pour la facture)</span></label>
                    <input type="number" id="o-total" placeholder="ex: 25.00" step="0.01" min="0" />
                  </div>
                </div>
                <div class="modal-foot">
                  <button type="button" id="order-cancel" class="btn-outline">Annuler</button>
                  <button type="submit" id="order-save" class="btn-primary">Enregistrer</button>
                </div>
              </form>
            </div>
          </div>

          <!-- Liste commandes -->
          <div id="orders-list" class="prints-list"></div>
          <div id="orders-empty" style="display:none" class="list-empty">
            <p>Aucune commande pour l'instant. Crée la première !</p>
          </div>
        </div><!-- fin tab-commandes -->

        <!-- ═══ TAB FILAMENTS ═══ -->
        <div id="tab-filaments" class="tab-content" style="display:none">
          <div class="admin-top">
            <div>
              <h1>Filaments</h1>
              <p class="admin-sub">Gère les couleurs et types de filaments disponibles à la commande</p>
            </div>
            <button id="open-filament" class="btn-primary">+ Ajouter un filament</button>
          </div>

          <!-- Modal filament -->
          <div id="fil-modal-overlay" class="modal-overlay" style="display:none">
            <div class="modal" style="max-width:480px">
              <div class="modal-head">
                <h3 id="fil-modal-title">Nouveau filament</h3>
                <button id="fil-modal-close" class="modal-x">×</button>
              </div>
              <form id="fil-form">
                <input type="hidden" id="fil-edit-id" />
                <div class="mform-row">
                  <div class="mfield">
                    <label>Nom <span class="req">*</span></label>
                    <input type="text" id="fil-name" placeholder="ex: Blanc, Rouge vif…" required />
                  </div>
                  <div class="mfield">
                    <label>Type <span class="req">*</span></label>
                    <select id="fil-type" required>
                      <option value="PLA">PLA</option>
                      <option value="ABS">ABS</option>
                      <option value="ASA">ASA</option>
                      <option value="PETG">PETG</option>
                      <option value="TPU">TPU</option>
                    </select>
                  </div>
                </div>
                <div class="mfield">
                  <label>Couleur <span class="req">*</span></label>
                  <div class="preset-colors-grid">
                    <button type="button" class="preset-color-btn" data-hex="#FFFFFF" data-name="Blanc" title="Blanc" style="background:#FFFFFF"></button>
                    <button type="button" class="preset-color-btn" data-hex="#F5E6C8" data-name="Naturel" title="Naturel" style="background:#F5E6C8"></button>
                    <button type="button" class="preset-color-btn" data-hex="#CCCCCC" data-name="Gris clair" title="Gris clair" style="background:#CCCCCC"></button>
                    <button type="button" class="preset-color-btn" data-hex="#888888" data-name="Gris" title="Gris" style="background:#888888"></button>
                    <button type="button" class="preset-color-btn" data-hex="#1C1C1C" data-name="Noir" title="Noir" style="background:#1C1C1C"></button>
                    <button type="button" class="preset-color-btn" data-hex="#E62020" data-name="Rouge" title="Rouge" style="background:#E62020"></button>
                    <button type="button" class="preset-color-btn" data-hex="#FF6B00" data-name="Orange" title="Orange" style="background:#FF6B00"></button>
                    <button type="button" class="preset-color-btn" data-hex="#FFD700" data-name="Jaune" title="Jaune" style="background:#FFD700"></button>
                    <button type="button" class="preset-color-btn" data-hex="#22AA44" data-name="Vert" title="Vert" style="background:#22AA44"></button>
                    <button type="button" class="preset-color-btn" data-hex="#006400" data-name="Vert foncé" title="Vert foncé" style="background:#006400"></button>
                    <button type="button" class="preset-color-btn" data-hex="#00BFFF" data-name="Bleu clair" title="Bleu clair" style="background:#00BFFF"></button>
                    <button type="button" class="preset-color-btn" data-hex="#1E60FF" data-name="Bleu" title="Bleu" style="background:#1E60FF"></button>
                    <button type="button" class="preset-color-btn" data-hex="#003380" data-name="Bleu marine" title="Bleu marine" style="background:#003380"></button>
                    <button type="button" class="preset-color-btn" data-hex="#8A2BE2" data-name="Violet" title="Violet" style="background:#8A2BE2"></button>
                    <button type="button" class="preset-color-btn" data-hex="#FF69B4" data-name="Rose" title="Rose" style="background:#FF69B4"></button>
                    <button type="button" class="preset-color-btn" data-hex="#8B4513" data-name="Marron" title="Marron" style="background:#8B4513"></button>
                  </div>
                  <div class="color-pick-row" style="margin-top:0.5rem">
                    <input type="color" id="fil-color" value="#888888" class="color-picker-input" />
                    <input type="text" id="fil-color-hex" value="#888888" placeholder="#RRGGBB" maxlength="7" />
                    <div id="fil-color-preview" class="color-preview-swatch" style="background:#888888"></div>
                  </div>
                </div>
                <div class="mfield mfield-check" style="margin-top:0.25rem">
                  <label class="check-lbl">
                    <input type="checkbox" id="fil-available" checked />
                    <span>Disponible pour commande</span>
                  </label>
                </div>
                <div class="modal-foot">
                  <button type="button" id="fil-cancel" class="btn-outline">Annuler</button>
                  <button type="submit" id="fil-save" class="btn-primary">Enregistrer</button>
                </div>
              </form>
            </div>
          </div>

          <!-- Liste filaments -->
          <div id="filaments-grid" class="filaments-grid"></div>
          <div id="filaments-empty" style="display:none" class="list-empty">
            <p>Aucun filament pour l'instant. Ajoute tes couleurs disponibles !</p>
          </div>
        </div><!-- fin tab-filaments -->

        <!-- ═══ TAB CLIENTS ═══ -->
        <div id="tab-clients" class="tab-content" style="display:none">
          <div class="admin-top">
            <div>
              <h1>Clients</h1>
              <p class="admin-sub">Gérez vos clients</p>
            </div>
            <button id="open-client" class="btn-primary">+ Nouveau client</button>
          </div>
          <div id="clients-stats" class="stats-row"></div>
          <div id="clients-list" class="prints-list"></div>
          <div id="clients-empty" style="display:none" class="list-empty">
            <p>Aucun client pour l'instant. Ajoute le premier !</p>
          </div>
        </div><!-- fin tab-clients -->

        <!-- ═══ TAB FACTURES ═══ -->
        <div id="tab-factures" class="tab-content" style="display:none">
          <div class="admin-top">
            <div>
              <h1>Factures</h1>
              <p class="admin-sub">Créez et gérez les factures de vos clients</p>
            </div>
            <button id="open-invoice" class="btn-primary">+ Nouvelle facture</button>
          </div>
          <div id="invoices-stats" class="stats-row"></div>
          <div id="invoices-list" class="prints-list"></div>
          <div id="invoices-empty" style="display:none" class="list-empty">
            <p>Aucune facture pour l'instant. Crée la première !</p>
          </div>
        </div><!-- fin tab-factures -->

      </div>
    </div>

  </main>

  <!-- ═══ MODAL CLIENT ═══ -->
  <div id="client-modal-overlay" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:560px">
      <div class="modal-head">
        <h3 id="client-modal-title">Nouveau client</h3>
        <button id="client-modal-close" class="modal-x">×</button>
      </div>
      <form id="client-form">
        <input type="hidden" id="c-edit-id" />
        <div class="mform-row">
          <div class="mfield"><label>Nom complet <span class="req">*</span></label><input type="text" id="c-name" placeholder="Marie Tremblay" required /></div>
          <div class="mfield"><label>Entreprise <span class="opt">(optionnel)</span></label><input type="text" id="c-company" placeholder="Optionnel" /></div>
        </div>
        <div class="mform-row">
          <div class="mfield"><label>Courriel <span class="req">*</span></label><input type="email" id="c-email" placeholder="marie@exemple.com" required /></div>
          <div class="mfield"><label>Téléphone <span class="opt">(optionnel)</span></label><input type="tel" id="c-phone" placeholder="514-000-0000" /></div>
        </div>
        <div class="modal-foot">
          <button type="button" id="client-cancel" class="btn-outline">Annuler</button>
          <button type="submit" id="client-save" class="btn-primary">Enregistrer le client</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ═══ MODAL FACTURE ═══ -->
  <div id="invoice-modal-overlay" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:800px">
      <div class="modal-head">
        <h3 id="invoice-modal-title">Nouvelle facture</h3>
        <button id="invoice-modal-close" class="modal-x">×</button>
      </div>
      <form id="invoice-form">
        <input type="hidden" id="inv-edit-id" />
        <div class="mform-row">
          <div class="mfield">
            <label>Client <span class="req">*</span></label>
            <div style="display:flex;gap:0.5rem;align-items:center">
              <select id="inv-client" required style="flex:1"><option value="">Choisir un client...</option></select>
              <button type="button" id="inv-new-client-btn" class="btn-outline" style="white-space:nowrap;flex-shrink:0;padding:0.45rem 0.85rem;font-size:0.82rem">+ Nouveau client</button>
            </div>
          </div>
          <div class="mfield">
            <label>Numéro de facture <span class="req">*</span></label>
            <input type="text" id="inv-number" placeholder="ADR-202601-001" required />
          </div>
        </div>
        <!-- Formulaire rapide nouveau client -->
        <div id="inv-quick-client" style="display:none;background:var(--surface-2,#f5f5f5);padding:1rem;border-radius:10px;border:1px solid var(--border,#e0e0e0);margin-bottom:0.25rem">
          <p style="font-weight:600;margin:0 0 0.75rem;font-size:0.9rem">Créer un nouveau client</p>
          <div class="mform-row">
            <div class="mfield"><label>Nom <span class="req">*</span></label><input type="text" id="qc-name" placeholder="Marie Tremblay" /></div>
            <div class="mfield"><label>Courriel</label><input type="email" id="qc-email" placeholder="marie@exemple.com" /></div>
          </div>
          <div class="mform-row">
            <div class="mfield"><label>Entreprise <span class="opt">(optionnel)</span></label><input type="text" id="qc-company" placeholder="Optionnel" /></div>
            <div class="mfield"><label>Téléphone <span class="opt">(optionnel)</span></label><input type="tel" id="qc-phone" placeholder="514-000-0000" /></div>
          </div>
          <div style="display:flex;gap:0.5rem;justify-content:flex-end;margin-top:0.5rem">
            <button type="button" id="qc-cancel" class="btn-outline" style="padding:0.4rem 1rem;font-size:0.82rem">Annuler</button>
            <button type="button" id="qc-save" class="btn-primary" style="padding:0.4rem 1rem;font-size:0.82rem">Créer le client</button>
          </div>
        </div>

