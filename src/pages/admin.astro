    const prog = document.getElementById('real-upload-progress');
    const bar  = document.getElementById('real-progress-bar');
    const lbl  = document.getElementById('real-progress-label');
    let newUrls = [];
    if (realSelectedFiles.length > 0) {
      prog.style.display = 'flex';
      for (let i = 0; i < realSelectedFiles.length; i++) {
        bar.style.width = `${Math.round((i / realSelectedFiles.length) * 100)}%`;
        lbl.textContent = `${i + 1} / ${realSelectedFiles.length}…`;
        const file = realSelectedFiles[i];
        const ext  = file.name.split('.').pop().toLowerCase();
        const name = `real-${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
        const { error } = await sb.storage.from('adrianne-prints').upload(name, file, { contentType: file.type });
        if (error) { prog.style.display = 'none'; throw error; }
        const { data: { publicUrl } } = sb.storage.from('adrianne-prints').getPublicUrl(name);
        newUrls.push(publicUrl);
      }
      bar.style.width = '100%'; lbl.textContent = '100%';
      setTimeout(() => { prog.style.display = 'none'; }, 600);
    }

    const allUrls = [...realExistingUrls, ...newUrls];
    const payload = {
      name:        document.getElementById('r-name').value.trim(),
      category:    document.getElementById('r-cat').value,
      description: document.getElementById('r-desc').value.trim(),
      featured:    document.getElementById('r-featured').checked,
      photo_url:   allUrls[0] || '',
      photo_urls:  allUrls,
    };

    if (editingRealId) {
      const { error: updateErr } = await sb.from('adrianne_realisations').update(payload).eq('id', editingRealId);
      if (updateErr) throw updateErr;
    } else {
      const { error: insertErr } = await sb.from('adrianne_realisations').insert(payload);
      if (insertErr) throw insertErr;
    }

    closeRealModal(); loadRealisations();
  } catch (err) { alert('Erreur : ' + err.message); }
  finally { saveBtn.disabled = false; saveText.textContent = 'Enregistrer'; }
});

