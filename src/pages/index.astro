---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Les 3D d'Adrianne — Impressions 3D artisanales">
  <Nav />
  <main>

    <!-- ═══ HERO ═══════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-deco"></div>
      <div class="container hero-inner">
        <div class="hero-text">
          <p class="hero-eyebrow anim-eyebrow">Créations uniques · Faites à la main</p>
          <h1 class="hero-h1">
            <span class="h1-line split-words">L'impression 3D</span><br/>
            <span class="h1-line"><em class="text-shimmer-rose split-words">réinventée</em><span class="split-words"> avec soin</span></span>
          </h1>
          <p class="hero-sub anim-sub">
            Figurines, décorations, objets personnalisés.<br/>
            Chaque pièce est imaginée, imprimée et livrée avec amour.
          </p>
          <div class="hero-actions anim-actions">
            <a href="/contact" class="btn-primary">Faire une commande</a>
            <a href="#galerie" class="btn-ghost">Voir les créations</a>
          </div>
        </div>
        <div class="hero-badge-wrap">
          <div class="hero-badge">
            <span class="hb-num">100%</span>
            <span class="hb-label">Fait avec<br/>passion</span>
          </div>
          <div class="hero-badge">
            <span class="hb-num">PLA · ABS · ASA</span>
            <span class="hb-label">Filaments<br/>de qualité</span>
          </div>
          <div class="hero-badge">
            <span class="hb-num">Sur</span>
            <span class="hb-label">commande<br/>personnalisée</span>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <span></span>
        <p>Défiler</p>
      </div>
    </section>

    <!-- ═══ GALERIE ═════════════════════════════════════════════ -->
    <section class="section" id="galerie">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow anim-eyebrow-scroll">Mes réalisations</p>
          <h2 class="split-words-scroll">Galerie de créations</h2>
          <p class="section-sub">Chaque pièce est unique. Clique sur une création pour en savoir plus.</p>
        </div>

        <!-- Filtres catégories -->
        <div class="filters reveal" id="filters">
          <button class="filter-btn active" data-cat="">Tout voir</button>
          <button class="filter-btn" data-cat="Figurines">Figurines</button>
          <button class="filter-btn" data-cat="Déco">Décoration</button>
          <button class="filter-btn" data-cat="Utilitaires">Utilitaires</button>
          <button class="filter-btn" data-cat="Cadeaux">Cadeaux</button>
        </div>

        <!-- Grille chargée via JS -->
        <div id="gallery-grid" class="gallery-grid">
          <div class="gallery-skeleton"></div>
          <div class="gallery-skeleton"></div>
          <div class="gallery-skeleton"></div>
          <div class="gallery-skeleton"></div>
        </div>
        <div id="gallery-empty" style="display:none" class="gallery-empty">
          <p>✨ Les premières créations arrivent bientôt !</p>
        </div>
      </div>
    </section>

    <!-- ═══ À PROPOS ════════════════════════════════════════════ -->
    <section class="section section-alt" id="apropos">
      <div class="container apropos-inner">
        <div class="ap-deco reveal">
          <div class="ap-circle">
            <span>A</span>
          </div>
        </div>
        <div class="ap-text reveal">
          <p class="eyebrow anim-eyebrow-scroll">À propos</p>
          <h2 class="split-words-scroll">Bonjour, je suis Adrianne</h2>
          <p>Passionnée par l'impression 3D depuis plusieurs années, je crée des pièces uniques qui allient technique et créativité. Chaque commande est traitée avec soin, du choix du filament jusqu'à l'emballage final.</p>
          <p>Que ce soit pour un cadeau original, une figurine de votre personnage préféré ou une pièce décorative pour votre maison — je m'occupe de tout.</p>
          <a href="/contact" class="btn-primary" style="margin-top:1.5rem;display:inline-flex">Me contacter</a>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ══════════════════════════════════════════════════ -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-card reveal">
          <p class="eyebrow anim-eyebrow-scroll">Prêt·e à commander ?</p>
          <h2 class="split-words-scroll">Donnez vie à votre idée</h2>
          <p>Décrivez ce que vous imaginez, je m'occupe du reste. Délai habituel : 3 à 7 jours.</p>
          <a href="/contact" class="btn-primary btn-lg">Faire une demande</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
import { createClient } from '@supabase/supabase-js';
const SB_URL = 'https://gnpjilwdehxsafdqdtak.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImducGppbHdkZWh4c2FmZHFkdGFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Nzk3NjIsImV4cCI6MjA5NTU1NTc2Mn0.iFYR9r5ZZsKcc9n2N8jPtFTLs0QDTIqR3KMCMhCdSdA';
const sb = createClient(SB_URL, SB_KEY);

let allPrints = [];
let activeFilter = '';

async function loadPrints() {
  const { data } = await sb.from('adrianne_prints').select('*').order('created_at', { ascending: false });
  allPrints = data || [];
  renderGallery(allPrints);
}

function renderGallery(prints) {
  const grid  = document.getElementById('gallery-grid');
  const empty = document.getElementById('gallery-empty');
  grid.innerHTML = '';
  if (!prints.length) { empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  prints.forEach((p, i) => {
    const photos = p.photo_urls?.length ? p.photo_urls : (p.photo_url ? [p.photo_url] : []);
    const hasMany = photos.length > 1;

    const card = document.createElement('div');
    card.className = 'gcard';
    card.style.animationDelay = `${i * 0.07}s`;
    card.innerHTML = `
      <div class="gcard-img">
        ${photos.length
          ? `<img src="${photos[0]}" alt="${p.name}" loading="lazy" />`
          : `<div class="gcard-placeholder"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".25"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>`}
        ${hasMany ? `
          <button class="gcard-nav gcard-prev" type="button" aria-label="Photo précédente">&#8249;</button>
          <button class="gcard-nav gcard-next" type="button" aria-label="Photo suivante">&#8250;</button>
          <div class="gcard-dots">${photos.map((_, j) => `<span class="gcard-dot${j === 0 ? ' active' : ''}"></span>`).join('')}</div>
        ` : ''}
        ${p.featured ? '<span class="gcard-badge">Coup de cœur ✨</span>' : ''}
        <div class="gcard-cat">${p.category}</div>
      </div>
      <div class="gcard-body">
        <h3>${p.name}</h3>
        ${p.description ? `<p>${p.description}</p>` : ''}
        <div class="gcard-foot">
          ${p.price_range ? `<span class="gcard-price">À partir de ${p.price_range}</span>` : ''}
          ${p.price_cents
            ? `<button class="gcard-btn gcard-buy" data-name="${p.name.replace(/"/g, '&quot;')}" data-price="${p.price_cents}" data-image="${(photos[0] || '').replace(/"/g, '&quot;')}" data-id="${p.id}">Acheter</button>`
            : `<a href="/contact?produit=${encodeURIComponent(p.name)}" class="gcard-btn">Commander</a>`
          }
        </div>
      </div>`;

    if (hasMany) {
      let idx = 0;
      const img  = card.querySelector('img');
      const dots = card.querySelectorAll('.gcard-dot');
      function goTo(n) {
        idx = (n + photos.length) % photos.length;
        img.src = photos[idx];
        dots.forEach((d, j) => d.classList.toggle('active', j === idx));
      }
      card.querySelector('.gcard-prev').addEventListener('click', e => { e.preventDefault(); goTo(idx - 1); });
      card.querySelector('.gcard-next').addEventListener('click', e => { e.preventDefault(); goTo(idx + 1); });
    }

    grid.appendChild(card);
  });

  grid.querySelectorAll('.gcard-buy').forEach(btn => {
    btn.addEventListener('click', async () => {
      btn.textContent = '…';
      btn.disabled = true;
      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: btn.dataset.name,
            price_cents: parseInt(btn.dataset.price),
            image_url: btn.dataset.image || undefined,
            product_id: btn.dataset.id,
          }),
        });
        const { url, error } = await res.json();
        if (url) { window.location.href = url; }
        else { throw new Error(error || 'Erreur de paiement'); }
      } catch (e) {
        alert(e.message);
        btn.textContent = 'Acheter';
        btn.disabled = false;
      }
    });
  });
}

// Filtres
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.cat;
    const filtered = activeFilter ? allPrints.filter(p => p.category === activeFilter) : allPrints;
    renderGallery(filtered);
  });
});

loadPrints();
</script>

<style>
  main { padding-top: 68px; }

  /* Buttons */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--accent); color: var(--white);
    padding: 0.75rem 1.75rem; border-radius: 999px;
    font-size: 0.875rem; font-weight: 600; border: none; cursor: pointer;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s; letter-spacing: 0.02em;
  }
  .btn-primary:hover { background: var(--accent-d); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(42,92,180,0.3); }
  .btn-primary.btn-lg { padding: 0.9rem 2.25rem; font-size: 0.95rem; }
  .btn-ghost {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--text-2); padding: 0.75rem 1.75rem; border-radius: 999px;
    font-size: 0.875rem; font-weight: 500; border: 1.5px solid var(--border);
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

  .section { padding: 6rem 2rem; }
  .section-alt { background: var(--bg2); }
  .eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  .section-header { text-align: center; margin-bottom: 3.5rem; }
  .section-header h2 { font-size: clamp(1.8rem, 4vw, 3rem); margin-bottom: 0.75rem; }
  .section-sub { font-size: 0.9rem; color: var(--text-2); max-width: 440px; margin: 0 auto; line-height: 1.7; }

  /* Hero */
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none} }
  @keyframes scrollLine { 0%,100%{opacity:0.3;transform:scaleY(0.5)}50%{opacity:1;transform:scaleY(1)} }
  .hero { position: relative; min-height: 92vh; display: flex; align-items: center; overflow: hidden; padding: 5rem 2rem 4rem; }
  .hero-deco {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 60% 70% at 85% 35%, rgba(42,92,180,0.12) 0%, transparent 60%),
                radial-gradient(ellipse 45% 45% at 12% 72%, rgba(192,138,56,0.07) 0%, transparent 55%);
  }
  .hero-inner { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 4rem; flex-wrap: wrap; }
  .hero-text { max-width: 560px; }
  .hero-eyebrow { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.25rem; animation: fadeUp 0.6s ease 0.1s both; }
  .hero h1 { font-size: clamp(2.8rem, 7vw, 5.5rem); font-weight: 600; margin-bottom: 1.5rem; line-height: 1.05; animation: fadeUp 0.8s ease 0.25s both; }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero-sub { font-size: 1rem; color: var(--text-2); line-height: 1.75; margin-bottom: 2.5rem; animation: fadeUp 0.7s ease 0.45s both; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.6s ease 0.6s both; }
  .hero-badge-wrap { display: flex; flex-direction: column; gap: 1rem; animation: fadeUp 0.7s ease 0.5s both; }
  .hero-badge { display: flex; align-items: center; gap: 0.75rem; background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 0.85rem 1.25rem; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
  .hb-num { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 700; color: var(--accent); line-height: 1; min-width: 40px; }
  .hb-label { font-size: 0.75rem; color: var(--text-2); line-height: 1.4; }
  .hero-scroll { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.4rem; animation: fadeUp 0.6s ease 1s both; }
  .hero-scroll span { display: block; width: 1px; height: 32px; background: linear-gradient(to bottom, transparent, var(--accent)); animation: scrollLine 1.6s ease infinite; }
  .hero-scroll p { font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(13,27,46,0.35); }

  /* Filtres */
  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; justify-content: center; }
  .filter-btn {
    background: var(--white); border: 1.5px solid var(--border); color: var(--text-2);
    padding: 0.45rem 1.1rem; border-radius: 999px; font-size: 0.82rem; font-weight: 500;
    cursor: pointer; transition: all 0.2s; font-family: 'DM Sans', sans-serif;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active { background: var(--accent); border-color: var(--accent); color: var(--white); }

  /* Galerie */
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @keyframes gcardIn { from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none} }
  .gcard { background: var(--white); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; animation: gcardIn 0.4s ease-out both; }
  .gcard:hover { transform: translateY(-5px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
  .gcard-img { position: relative; aspect-ratio: 4/3; background: var(--bg2); overflow: hidden; }
  .gcard-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .gcard:hover .gcard-img img { transform: scale(1.04); }
  .gcard-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-2); }
  .gcard-badge { position: absolute; top: 0.75rem; left: 0.75rem; background: var(--accent); color: var(--white); font-size: 0.68rem; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 999px; z-index: 2; }
  .gcard-cat { position: absolute; bottom: 0.75rem; right: 0.75rem; background: rgba(237,242,248,0.92); backdrop-filter: blur(4px); font-size: 0.68rem; font-weight: 600; color: var(--text-2); padding: 0.2rem 0.6rem; border-radius: 999px; border: 1px solid var(--border); letter-spacing: 0.04em; z-index: 2; }

  /* Carousel */
  .gcard-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(237,242,248,0.9); border: none; border-radius: 50%; width: 28px; height: 28px; font-size: 1.2rem; line-height: 1; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text); z-index: 3; opacity: 0; transition: opacity 0.2s, background 0.2s; padding: 0; }
  .gcard:hover .gcard-nav { opacity: 1; }
  .gcard-nav:hover { background: var(--white); }
  .gcard-prev { left: 0.4rem; }
  .gcard-next { right: 0.4rem; }
  .gcard-dots { position: absolute; bottom: 0.45rem; left: 50%; transform: translateX(-50%); display: flex; gap: 4px; z-index: 2; }
  .gcard-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(237,242,248,0.45); transition: background 0.2s; }
  .gcard-dot.active { background: var(--white); }
  .gcard-body { padding: 1.25rem; }
  .gcard-body h3 { font-size: 1.05rem; font-weight: 600; font-family: 'Cormorant Garamond', serif; margin-bottom: 0.4rem; }
  .gcard-body p { font-size: 0.82rem; color: var(--text-2); line-height: 1.6; margin-bottom: 0.75rem; }
  .gcard-foot { display: flex; align-items: center; justify-content: space-between; }
  .gcard-price { font-size: 0.85rem; font-weight: 600; color: var(--accent); font-family: 'Cormorant Garamond', serif; font-style: italic; }
  .gcard-btn { background: var(--accent-l); color: var(--accent); padding: 0.35rem 0.85rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; transition: background 0.2s; letter-spacing: 0.03em; }
  .gcard-btn:hover { background: var(--accent); color: var(--white); }
  .gcard-buy { background: var(--accent); color: var(--white); border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; }
  .gcard-buy:hover { background: var(--accent-d); }
  .gcard-buy:disabled { opacity: 0.6; cursor: not-allowed; }
  .gallery-skeleton { background: linear-gradient(90deg, var(--bg2) 25%, var(--border) 50%, var(--bg2) 75%); background-size: 200% 100%; animation: shimmer 1.6s infinite; border-radius: 16px; aspect-ratio: 3/4; }
  @keyframes shimmer { to { background-position: -200% 0; } }
  .gallery-empty { text-align: center; padding: 5rem 2rem; color: var(--text-2); font-style: italic; }

  /* À propos */
  .apropos-inner { display: grid; grid-template-columns: 240px 1fr; gap: 5rem; align-items: center; }
  .ap-deco { display: flex; justify-content: center; }
  .ap-circle { width: 200px; height: 200px; border-radius: 50%; background: linear-gradient(135deg, var(--accent-l), rgba(192,138,56,0.1)); border: 2px solid rgba(42,92,180,0.25); display: flex; align-items: center; justify-content: center; }
  .ap-circle span { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 6rem; color: var(--accent); font-weight: 300; line-height: 1; }
  .ap-text h2 { font-size: clamp(1.75rem, 3.5vw, 2.75rem); margin-bottom: 1.25rem; }
  .ap-text p { font-size: 0.925rem; color: var(--text-2); line-height: 1.8; margin-bottom: 0.75rem; }

  /* CTA */
  .cta-section { background: var(--dark); }
  .cta-section .eyebrow { color: var(--gold); }
  .cta-card { text-align: center; max-width: 560px; margin: 0 auto; }
  .cta-card h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: 1rem; color: #EDF2F8; }
  .cta-card p { font-size: 0.95rem; color: rgba(237,242,248,0.6); margin-bottom: 2rem; line-height: 1.7; }
  .cta-section .btn-primary { background: #EDF2F8; color: var(--dark); box-shadow: none; }
  .cta-section .btn-primary:hover { background: #FFFFFF; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.25); }

  /* Responsive */
  @media (max-width: 960px) { .hero-badge-wrap { display: none; } .apropos-inner { grid-template-columns: 1fr; gap: 2rem; } .ap-deco { display: none; } }
  @media (max-width: 700px) { .gallery-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; } }
</style>
