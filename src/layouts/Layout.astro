---
export interface Props { title: string; description?: string; image?: string }
const {
  title,
  description = "Impressions 3D artisanales créées avec passion par Adrianne. Figurines, décorations et objets personnalisés sur commande.",
  image = "/og-image.jpg",
} = Astro.props;
const siteUrl  = 'https://les3darianne.xyz';
const pageUrl  = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const jsonLd   = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Les 3D d'Adrianne",
  "description": description,
  "url": siteUrl,
  "image": imageUrl,
  "priceRange": "$$",
  "serviceType": "Impression 3D sur commande",
  "areaServed": "Québec, Canada",
  "offers": {
    "@type": "Offer",
    "description": "Impressions 3D personnalisées : figurines, décorations, objets utilitaires",
    "priceCurrency": "CAD"
  }
});
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={pageUrl} />

  <!-- Open Graph (Facebook, WhatsApp, etc.) -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={pageUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={imageUrl} />
  <meta property="og:locale"      content="fr_CA" />
  <meta property="og:site_name"   content="Les 3D d'Adrianne" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={imageUrl} />

  <!-- JSON-LD : données structurées pour Google -->
  <Fragment set:html={`<script type="application/ld+json">${jsonLd}</script>`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #EDF2F8;
      --bg2:      #DDE8F4;
      --bg3:      #FFFFFF;
      --text:     #0D1B2E;
      --text-2:   #4A5870;
      --accent:   #2A5CB4;
      --accent-d: #1A3A80;
      --accent-l: rgba(42,92,180,0.1);
      --gold:     #C08A38;
      --border:   #C0D0E8;
      --dark:     #0D1B2E;
      --white:    #FFFFFF;
      --radius:   12px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.01em;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button { font-family: 'DM Sans', sans-serif; }

    .container { max-width: 1160px; margin: 0 auto; padding: 0 2rem; }

    /* Reveal animation */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible { opacity: 1; transform: none; }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--accent); opacity: 0.4; border-radius: 3px; }
  </style>
</head>
<body>
  <slot />

  <!-- ░░ OVERLAY "EN DÉVELOPPEMENT" ░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
  <div id="dev-overlay">
    <div class="dev-inner">
      <div id="dev-logo" title="...">A</div>
      <p class="dev-eyebrow">Bientôt disponible</p>
      <h1>Les 3D d'Adrianne</h1>
      <p class="dev-sub">
        Le site est en cours de création.<br/>
        Revenez bientôt pour découvrir mes créations 3D artisanales.
      </p>
      <div class="dev-dots">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <p class="dev-contact">
        Une question ? <a href="mailto:contact@les3darianne.xyz">Écrivez-moi</a>
      </p>
    </div>
  </div>

  <style>
    #dev-overlay {
      position: fixed; inset: 0; z-index: 9999;
      background: #EDF2F8;
      display: flex; align-items: center; justify-content: center;
      padding: 2rem;
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    #dev-overlay.hidden {
      opacity: 0; pointer-events: none; transform: scale(1.02);
    }
    .dev-inner { text-align: center; max-width: 480px; }
    #dev-logo {
      width: 72px; height: 72px; border-radius: 50%;
      background: var(--accent); color: white;
      font-family: 'Cormorant Garamond', serif; font-style: italic;
      font-size: 2.2rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 2rem; cursor: default;
      box-shadow: 0 4px 20px rgba(42,92,180,0.3);
      transition: transform 0.1s, box-shadow 0.2s;
      user-select: none;
    }
    #dev-logo.tap { transform: scale(0.88); box-shadow: 0 2px 8px rgba(42,92,180,0.2); }
    .dev-eyebrow {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem;
    }
    #dev-overlay h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 600;
      color: var(--text); margin-bottom: 1.25rem; letter-spacing: -0.01em;
    }
    .dev-sub {
      font-size: 0.95rem; color: var(--text-2);
      line-height: 1.75; margin-bottom: 2.5rem;
    }
    .dev-dots {
      display: flex; justify-content: center; gap: 8px; margin-bottom: 2rem;
    }
    .dev-dots span {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--border);
      transition: background 0.2s, transform 0.2s;
    }
    .dev-dots span.active { background: var(--accent); transform: scale(1.3); }
    .dev-contact { font-size: 0.82rem; color: var(--text-2); }
    .dev-contact a { color: var(--accent); text-decoration: underline; }
  </style>

  <script>
    // ── Page admin : pas d'overlay ───────────────────────────────
    const isAdmin = window.location.pathname.startsWith('/admin');

    const overlay = document.getElementById('dev-overlay');
    const logo    = document.getElementById('dev-logo');
    const dots    = overlay.querySelectorAll('.dev-dots span');

    function unlock() {
      localStorage.setItem('adr-dev-access', '1');
      overlay.classList.add('hidden');
      setTimeout(() => overlay.remove(), 600);
    }

    // Déjà débloqué ou page admin → cacher l'overlay
    if (isAdmin || localStorage.getItem('adr-dev-access') === '1') {
      overlay.remove();
    } else {
      // Compter les clics sur le logo (5 clics en moins de 4 secondes)
      let clicks = 0, timer = null;

      logo.addEventListener('click', () => {
        clicks++;
        logo.classList.add('tap');
        setTimeout(() => logo.classList.remove('tap'), 120);

        // Allumer les points
        dots.forEach((d, i) => d.classList.toggle('active', i < clicks));

        clearTimeout(timer);
        if (clicks >= 5) {
          unlock();
        } else {
          // Reset après 4 secondes sans clic
          timer = setTimeout(() => {
            clicks = 0;
            dots.forEach(d => d.classList.remove('active'));
          }, 4000);
        }
      });
    }

    // ── Reveal animations (pages normales) ──────────────────────
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  </script>
</body>
</html>
