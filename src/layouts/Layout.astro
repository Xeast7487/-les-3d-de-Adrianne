---
export interface Props { title: string; description?: string; image?: string }
const {
  title,
  description = "Impressions 3D artisanales créées avec passion par Adrianne. Figurines, décorations et objets personnalisés sur commande.",
  image = "/og-image.jpg",
} = Astro.props;
const siteUrl  = 'https://les3darianne.xyz';
const pageUrl  = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const jsonLd   = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Les 3D d'Adrianne",
  "description": description,
  "url": siteUrl,
  "image": imageUrl,
  "priceRange": "$$",
  "serviceType": "Impression 3D sur commande",
  "areaServed": "Québec, Canada",
  "offers": {
    "@type": "Offer",
    "description": "Impressions 3D personnalisées : figurines, décorations, objets utilitaires",
    "priceCurrency": "CAD"
  }
});
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={pageUrl} />

  <!-- Open Graph (Facebook, WhatsApp, etc.) -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={pageUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={imageUrl} />
  <meta property="og:locale"      content="fr_CA" />
  <meta property="og:site_name"   content="Les 3D d'Adrianne" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={imageUrl} />

  <!-- JSON-LD : données structurées pour Google -->
  <Fragment set:html={`<script type="application/ld+json">${jsonLd}</script>`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #EDF2F8;
      --bg2:      #DDE8F4;
      --bg3:      #FFFFFF;
      --text:     #0D1B2E;
      --text-2:   #4A5870;
      --accent:   #2A5CB4;
      --accent-d: #1A3A80;
      --accent-l: rgba(42,92,180,0.1);
      --gold:     #C08A38;
      --border:   #C0D0E8;
      --dark:     #0D1B2E;
      --white:    #FFFFFF;
      --radius:   12px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.01em;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button { font-family: 'DM Sans', sans-serif; }

    .container { max-width: 1160px; margin: 0 auto; padding: 0 2rem; }

    /* Reveal animation */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible { opacity: 1; transform: none; }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--accent); opacity: 0.4; border-radius: 3px; }

    /* ── Keyframes ── */
    @keyframes eyebrowSlide {
      from { opacity: 0; transform: translateX(-16px); letter-spacing: 0.3em; }
      to   { opacity: 1; transform: none; letter-spacing: 0.18em; }
    }
    @keyframes wordUp {
      from { opacity: 0; transform: translateY(110%); }
      to   { opacity: 1; transform: none; }
    }
    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: none; }
    }
    @keyframes shimmerRose {
      0%   { background-position: 0% center; }
      100% { background-position: -200% center; }
    }

    /* ── Hero animations ── */
    .anim-eyebrow {
      animation: eyebrowSlide 0.8s cubic-bezier(0.22,1,0.36,1) 0.15s both;
    }
    .anim-sub {
      animation: fadeSlide 0.9s ease 0.85s both;
    }
    .anim-actions {
      animation: fadeSlide 0.8s ease 1.1s both;
    }

    /* ── Shimmer rose/or sur "réinventée" ── */
    .text-shimmer-rose {
      background: linear-gradient(
        90deg,
        var(--accent) 0%,
        #C4677A 25%,
        #C08A38 50%,
        #C4677A 75%,
        var(--accent) 100%
      );
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmerRose 4s linear infinite;
      font-style: italic;
    }

    /* ── Word split ── */
    .word-wrap {
      display: inline-block;
      overflow: hidden;
      vertical-align: bottom;
      line-height: 1.15;
    }
    .word-inner {
      display: inline-block;
      animation: wordUp 0.9s cubic-bezier(0.22,1,0.36,1) both;
    }

    /* ── Eyebrow scroll ── */
    .anim-eyebrow-scroll {
      opacity: 0;
      transition: opacity 0.6s ease, transform 0.6s ease, letter-spacing 0.6s ease;
      transform: translateX(-12px);
      letter-spacing: 0.3em !important;
    }
    .anim-eyebrow-scroll.visible {
      opacity: 1; transform: none; letter-spacing: 0.18em !important;
    }
  </style>
</head>
<body>
  <slot />

  <script>
    // ── Split words : hero (immédiat au chargement) ─────────────
    document.querySelectorAll('.split-words').forEach(el => {
      const isEm     = el.tagName === 'EM';
      const line2    = !!el.closest('.h1-line:last-child');
      const delay    = 0.38 + (line2 ? 0.22 : 0);
      const words    = el.textContent.trim().split(/\s+/);
      el.innerHTML   = '';
      if (isEm) el.removeAttribute('style');
      words.forEach((w, i) => {
        const wrap  = document.createElement('span');
        const inner = document.createElement('span');
        wrap.className  = 'word-wrap';
        inner.className = 'word-inner' + (isEm ? ' text-shimmer-rose' : '');
        inner.textContent = w;
        inner.style.animationDelay = `${(delay + i * 0.09).toFixed(2)}s`;
        wrap.appendChild(inner);
        el.appendChild(wrap);
        if (i < words.length - 1) el.appendChild(document.createTextNode(' '));
      });
    });

    // ── Split words : au scroll ──────────────────────────────────
    const splitObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el    = e.target;
        const words = el.textContent.trim().split(/\s+/);
        el.innerHTML = '';
        words.forEach((w, i) => {
          const wrap  = document.createElement('span');
          const inner = document.createElement('span');
          wrap.className  = 'word-wrap';
          inner.className = 'word-inner';
          inner.textContent = w;
          inner.style.animationDelay = `${(i * 0.1).toFixed(2)}s`;
          wrap.appendChild(inner);
          el.appendChild(wrap);
          if (i < words.length - 1) el.appendChild(document.createTextNode(' '));
        });
        splitObs.unobserve(el);
      });
    }, { threshold: 0.25 });
    document.querySelectorAll('.split-words-scroll').forEach(el => splitObs.observe(el));

    // ── Reveal standard ──────────────────────────────────────────
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal, .anim-eyebrow-scroll').forEach(el => obs.observe(el));
  </script>
</body>
</html>
